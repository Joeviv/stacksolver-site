---
import AnimatedGrid from './AnimatedGrid.astro';
---
<section class="hero-container">
  <AnimatedGrid />
  <div class="hero-content">
    <h1 class="hero-title">Stacksolver.tech</h1>
    <p class="hero-subtitle">Solucionamos y gestionamos todo tu stack tecnológico.</p>
  </div>
</section>

<style>
  .hero-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
    padding: 10rem 2rem;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--text-color-primary);
    line-height: 1.1;
    font-weight: 700;
    margin: 0 0 1.5rem 0;
  }
  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.3rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 550px;
    /* ¡CAMBIO CLAVE! Usamos el color blanco para máxima legibilidad. */
    color: var(--text-color-primary); 
  }
</style>