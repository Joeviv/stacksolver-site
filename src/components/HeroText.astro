---
// src/components/HeroText.astro
---
<section class="hero-text-container">
  <h1 class="hero-title">Stacksolver.tech</h1>
  <p class="hero-subtitle">Solucionamos y gestionamos todo tu stack tecnológico.</p>
</section>

<style>
  .hero-text-container {
    text-align: center;
    max-width: 750px; /* Controla el ancho del texto */
  }

  .hero-title {
    /* Fuente grande y fluida que se adapta al tamaño de la pantalla */
    font-size: clamp(2.5rem, 8vw, 5rem);
    color: var(--primary-text-color);
    margin: 0 0 1rem 0;
    line-height: 1.1;
    font-weight: 700;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: var(--secondary-text-color);
    max-width: 500px; /* Hacemos el subtítulo un poco más estrecho */
    margin: 0 auto;
    line-height: 1.6;
  }
</style>