---
import type { Service } from '../data/services';
interface Props {
  service: Service;
}
const { service } = Astro.props;
const firstFeatureMedia = service.page.features[0]?.media;
---

<div id={`service-${service.id}`} class="service-detail-container">
  <!-- Franja Blanca Superior con el Título -->
  <div class="title-bar">
    <div class="title-bar-content">
      <h2>{service.page.title}</h2>
      <p>{service.page.description}</p>
    </div>
  </div>

  <!-- Contenido Interactivo Principal -->
  <div class="interactive-content">
    <div class="features-list">
      <ul>
        {service.page.features.map((feature, index) => (
          <li 
            class="feature-item" 
            data-media-type={feature.media.type}
            data-media-src={feature.media.src}
            data-media-alt={feature.media.alt}
          >
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </li>
        ))}
      </ul>
    </div>
    <div class="media-viewer">
      <div class="media-sticky-wrapper">
        <div class="media-display">
          {firstFeatureMedia && (
            firstFeatureMedia.type === 'image' ? (
                <img src={firstFeatureMedia.src} alt={firstFeatureMedia.alt} />
            ) : (
                <video src={firstFeatureMedia.src} autoplay loop muted playsinline></video>
            )
          )}
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // NOTA: Hacemos este script 'is:inline' para máxima fiabilidad
  function initializeServiceDetailInteractivity() {
    const featureItems = document.querySelectorAll('.feature-item');

    featureItems.forEach(item => {
      // Evitar añadir el listener varias veces
      if (item.dataset.hoverListenerAttached) return;

      item.addEventListener('mouseenter', () => {
        const container = item.closest('.interactive-content');
        if (!container) return;
        
        const mediaDisplay = container.querySelector('.media-display');
        if (!mediaDisplay) return;

        const mediaType = item.dataset.mediaType;
        const mediaSrc = item.dataset.mediaSrc;
        const mediaAlt = item.dataset.mediaAlt;

        let newMediaElement;
        if (mediaType === 'image') {
          newMediaElement = document.createElement('img');
          newMediaElement.src = mediaSrc;
          newMediaElement.alt = mediaAlt;
        } else {
          newMediaElement = document.createElement('video');
          newMediaElement.src = mediaSrc;
          newMediaElement.autoplay = true;
          newMediaElement.loop = true;
          newMediaElement.muted = true;
          newMediaElement.playsInline = true;
        }
        
        mediaDisplay.style.opacity = '0';
        setTimeout(() => {
          mediaDisplay.innerHTML = '';
          mediaDisplay.appendChild(newMediaElement);
          mediaDisplay.style.opacity = '1';
        }, 200);
      });

      item.dataset.hoverListenerAttached = 'true';
    });
  }
  document.addEventListener('DOMContentLoaded', initializeServiceDetailInteractivity);
  document.addEventListener('astro:page-load', initializeServiceDetailInteractivity);
</script>

<style>
  .service-detail-container {
    display: none;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    margin-top: -6rem;
  }

  /* --- AÑADIDO CLAVE AQUÍ --- */
  /* Esta clase, controlada por el script de index.astro, hace que el contenedor sea visible. */
  .service-detail-container.is-visible {
    opacity: 1;
  }
  /* --- FIN DEL AÑADIDO --- */

  .title-bar {
    background-color: #FFFFFF;
    color: #0A0A0A;
    padding: 4rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
  }
  .title-bar-content {
    max-width: 800px;
    margin: 0 auto;
  }
  .title-bar h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #0A0A0A;
    margin: 0 0 1rem 0;
  }
  .title-bar p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #333;
    line-height: 1.6;
    margin: 0;
  }

  .interactive-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 1400px;
    margin: 6rem auto;
    padding: 0 2rem;
  }
  @media (min-width: 992px) {
    .interactive-content {
      grid-template-columns: repeat(2, 1fr);
      gap: 5rem;
    }
  }

  .features-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .feature-item {
    padding: 2rem;
    border-radius: 12px;
    cursor: default;
    border: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  .feature-item:hover {
    background-color: rgba(255, 255, 255, 0.03);
    border-color: var(--border-color);
  }
  .feature-item h3 {
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
    color: var(--text-color-primary);
  }
  .feature-item p {
    font-size: 1rem;
    color: var(--text-color-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .media-viewer {
    position: relative;
    min-height: 400px;
  }
  .media-sticky-wrapper {
    position: sticky;
    top: 100px;
  }
  .media-display {
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    background-color: #000;
    transition: opacity 0.2s ease-in-out;
  }
  .media-display img,
  .media-display video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>