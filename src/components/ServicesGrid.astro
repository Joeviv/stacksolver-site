---
const { services } = Astro.props;
---
<div class="services-grid-wrapper">
    <div class="services-grid-container">
        {services.map((service, index) => (
            <a 
              href={service.link} 
              class="service-card" 
              style={`--animation-order: ${index};`}
              data-service-id={service.id}  
            >
                <div class="card-preview-wrapper">
                    <img src={service.previewImageUrl} alt={`Vista previa de ${service.displayTitle}`} class="preview-image" loading="lazy" width="400" height="225"/>
                </div>
                <div class="card-text-content">
                    <h2 class="service-display-title">{service.displayTitle}</h2>
                    <p class="service-subtitle">{service.subtitle}</p>
                </div>
            </a>
        ))}
    </div>
</div>
<style>
    .services-grid-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 0 1rem;
        box-sizing: border-box;
    }

    .services-grid-container {
        display: grid;
        width: 100%;
        /* 1. Aumentamos el espacio para que quepan las tarjetas más grandes */
        max-width: 1800px; 
        gap: 1.5rem;
        
        /* 2. RESTAURAMOS EL COMPORTAMIENTO RESPONSIVO CON GRID */
        grid-template-columns: repeat(2, 1fr); /* 2 columnas en móvil */
    }
    @media (min-width: 768px) {
        .services-grid-container {
            grid-template-columns: repeat(3, 1fr); /* 3 columnas en tablet */
        }
    }
    @media (min-width: 1400px) { /* Un punto de quiebre más grande para 6 columnas */
        .services-grid-container {
            grid-template-columns: repeat(6, 1fr); /* 6 columnas en desktop */
        }
    }

    .service-card {
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        
        background-color: #1A1A1A;
        border: 1px solid var(--border-color);
        border-radius: 12px;

        padding: 1rem; /* Un padding intermedio */
        
        /* 3. AJUSTAMOS LA OPACIDAD INICIAL. 0.6 es menos tenue que antes. */
        opacity: 0.6; 
        transform: scale(1); /* Tamaño normal por defecto */
        transition: transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease, opacity 0.3s ease;
    }
    
    .service-card:hover {
        opacity: 1; /* Totalmente visible al pasar el cursor */
        transform: scale(1.05); /* Se agranda un 5% */
        background-color: #222222;
        border-color: #777;
        z-index: 10;
        position: relative;
    }

    .card-preview-wrapper { 
        width: 100%; 
        aspect-ratio: 16 / 9; 
        border-radius: 8px;
        overflow: hidden; 
    }
    .preview-image { 
        width: 100%; 
        height: 100%; 
        object-fit: cover; 
    }

    .card-text-content {
        text-align: left;
    }
    .service-display-title { 
        font-size: 1rem; /* Un poco más grande para legibilidad */
        color: var(--text-color-primary); 
        margin: 0 0 0.25rem 0; 
        line-height: 1.2; 
        font-weight: 600; 
    }
    .service-subtitle { 
        font-size: 0.8rem; 
        color: var(--text-color-secondary); 
        margin: 0; 
    }
</style>