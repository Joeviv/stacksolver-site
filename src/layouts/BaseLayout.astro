---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// 1. Importar el componente SEO
import { SEO } from 'astro-seo';

// 2. Extender las props para incluir propiedades de SEO
const { 
  title, 
  description = "En Stacksolver.tech resolvemos tus problemas de negocio con tecnología. Ofrecemos IA local, desarrollo a medida con Claris FileMaker, diseño web con Astro y más.", 
  image = "/images/general/stacksolver-social-preview.jpg" // Crea una imagen genérica para compartir en redes
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- 3. Añadir el componente SEO con las props -->
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: Astro.url.origin + image,
          url: Astro.url.href
        }
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@tu_usuario_de_twitter', // Opcional: añade tu handle de Twitter
        creator: '@tu_usuario_de_twitter' // Opcional
      }}
      extend={{
        // Agrega cualquier otra metaetiqueta que necesites
        meta: [
          { name: 'author', content: 'Stacksolver.tech' }
        ]
      }}
    />

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Mona+Sans:wght@400;600;700&display=swap">
    <style is:global>
        :root {
            --background-color: #0A0A0A;
            --text-color-primary: #FFFFFF;
            --text-color-secondary: #A1A1A1;
            --border-color: #27272A;
        }
        html {
            font-family: 'Mona Sans', system-ui, sans-serif;
            background-color: var(--background-color);
            color: var(--text-color-secondary);
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }
        main {
            flex-grow: 1;
            width: 100%;
        }
        a {
            color: inherit;
            text-decoration: none;
        }
        h1, h2, h3 {
            color: var(--text-color-primary);
        }
    </style>
</head>
<body>
    <Header />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>