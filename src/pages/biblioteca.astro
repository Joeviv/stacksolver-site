function renderPage(id) {
  const l = document.documentElement.lang === 'en' ? 'en' : 'es';
  const d = PAGES[id][l] || PAGES[id]['es'];
  const tagsHtml = d.tags.map(([t,c]) => `<span class="tag ${c}">${t}</span>`).join('');
  const accHtml = d.acc.map(([q,a]) => `
    <div class="acc-item">
      <button class="acc-q" onclick="togAcc(this)">
        <span>${q}</span>
        <svg width="15" height="15"><use href="#V-ch"/></svg>
      </button>
      <div class="acc-a">${a}</div>
    </div>`).join('');

  // Partner badge for licencias
  const partnerBadge = id === 'lic'
    ? `<div class="partner-badge"><svg width="12" height="12"><use href="#V-ok"/></svg>Partner Oficial de Claris para Colombia</div>`
    : '';

  // Video block — real Vimeo player or placeholder
  const vimeoId = PAGES[id].vimeo;
  const videoBlock = vimeoId
    ? `<div class="sec-label">VIDEO</div>
       <div style="position:relative;width:100%;padding-bottom:56.25%;border-radius:10px;overflow:hidden;border:1px solid var(--border);margin-bottom:32px">
         <iframe src="https://player.vimeo.com/video/${vimeoId}?badge=0&autopause=0&player_id=0&app_id=58479"
           frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
           style="position:absolute;top:0;left:0;width:100%;height:100%" title=""></iframe>
       </div>`
    : `<div class="sec-label">VIDEO</div>
       <div class="video-wrap">
         <span class="video-badge">PRÓXIMAMENTE</span>
         <div class="video-icon"><svg width="18" height="18"><use href="#V-play"/></svg></div>
         <span class="video-label">Video explicativo disponible pronto</span>
       </div>`;

  return `
    <div class="breadcrumb"><span>StackSolver</span> / <span>${d.crumb}</span></div>
    <h1 class="page-title">${d.title}</h1>
    <p class="page-desc">${d.desc}</p>
    <div class="tags">${tagsHtml}</div>
    ${partnerBadge}
    ${videoBlock}
    <div class="divider-h"></div>
    <div class="sec-label">CONCEPTOS</div>
    <div class="acc-wrap">${accHtml}</div>
  `;
}

function showPage(id, el) {
  document.querySelectorAll('.sb-item').forEach(i => i.classList.remove('on'));
  if (el) el.classList.add('on');
  document.getElementById('pageContent').innerHTML = renderPage(id);
  window.scrollTo({ top: 0, behavior: 'smooth' });
  // close mobile sidebar
  document.getElementById('sidebar').classList.remove('open');
}

function togAcc(btn) {
  const item = btn.parentElement;
  const wasOpen = item.classList.contains('open');
  item.parentElement.querySelectorAll('.acc-item').forEach(i => i.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}

function toggleTheme() {
  document.body.classList.toggle('dark');
  const isDark = document.body.classList.contains('dark');
  document.getElementById('themeBtn').innerHTML = isDark
    ? '<svg width="14" height="14"><use href="#V-sun"/></svg>'
    : '<svg width="14" height="14"><use href="#V-moon"/></svg>';
}

function setLang(l) {
  document.documentElement.lang = l;
  document.querySelectorAll('.lb').forEach(b => b.classList.toggle('on', b.textContent === l.toUpperCase()));
  document.querySelectorAll('[data-es],[data-en]').forEach(el => {
    const v = el.getAttribute('data-' + l); if (v) el.innerHTML = v;
  });
  // re-render current page
  const active = document.querySelector('.sb-item.on');
  if (active) showPage(active.dataset.page, active);
}

function toggleSb() {
  document.getElementById('sidebar').classList.toggle('open');
}

// init
showPage('fin', document.querySelector('.sb-item[data-page="fin"]'));
