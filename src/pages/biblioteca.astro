<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Biblioteca — StackSolver</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#fafafa;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#6366f1;--indigo-sub:#eef2ff;
  --green:#16a34a;--green-sub:#f0fdf4;
  --amber:#d97706;--amber-sub:#fffbeb;
  --text:#18181b;--text2:#71717a;--text3:#a1a1aa;
  --r:6px;--font:'Inter',-apple-system,sans-serif;
  --sb:240px;--nav:52px;
}
body.dark{
  --bg:#0a0a0a;--surface:#111;--border:#27272a;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#18181b;--accent-sub:#27272a;
  --indigo:#818cf8;--indigo-sub:#1e1b4b;
  --green:#4ade80;--green-sub:#052e16;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav);display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:var(--bg);border-bottom:1px solid var(--border)}
.logo{font-size:14px;font-weight:700;letter-spacing:-.3px}
.logo em{color:var(--indigo);font-style:normal}
.nav-r{display:flex;gap:6px;align-items:center}
.nav-link{font-size:13px;color:var(--text2);padding:4px 10px;border-radius:var(--r);transition:all .15s}
.nav-link:hover{color:var(--text);background:var(--accent-sub)}
.nav-link.on{color:var(--text);font-weight:500}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2)}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}

/* LAYOUT */
.layout{display:flex;min-height:100vh;padding-top:var(--nav)}
.sidebar{width:var(--sb);flex-shrink:0;position:fixed;top:var(--nav);bottom:0;left:0;overflow-y:auto;border-right:1px solid var(--border);background:var(--bg);padding:16px 0}
.sidebar::-webkit-scrollbar{width:4px}
.sidebar::-webkit-scrollbar-track{background:transparent}
.sidebar::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.sb-section{font-size:11px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;color:var(--text3);padding:12px 16px 4px;margin-top:8px}
.sb-section:first-child{margin-top:0}
.sb-item{display:flex;align-items:center;gap:8px;padding:6px 16px;font-size:13px;font-weight:400;color:var(--text2);cursor:pointer;border-left:2px solid transparent;transition:all .1s}
.sb-item:hover{color:var(--text);background:var(--accent-sub)}
.sb-item.on{color:var(--text);font-weight:500;border-left-color:var(--text);background:var(--accent-sub)}
.sb-item svg{flex-shrink:0;width:14px;height:14px;opacity:.6}
.sb-item.on svg{opacity:1}
.sb-sub{padding-left:38px;font-size:12px;padding-top:4px;padding-bottom:4px;border-left:2px solid transparent}
.sb-sub:hover{color:var(--text);background:var(--accent-sub)}
.sb-sub.on{color:var(--text);font-weight:500;border-left-color:var(--text);background:var(--accent-sub)}

/* CONTENT */
.content{margin-left:var(--sb);flex:1;padding:48px 60px;max-width:calc(var(--sb) + 820px)}
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text3);margin-bottom:24px}
.breadcrumb span{color:var(--text2)}
.page-title{font-size:30px;font-weight:700;letter-spacing:-.6px;margin-bottom:6px;line-height:1.2}
.page-desc{font-size:15px;color:var(--text2);line-height:1.65;margin-bottom:32px;max-width:600px}
.divider-h{height:1px;background:var(--border);margin:32px 0}

/* SECTION LABEL */
.sec-label{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:12px}

/* VIDEO */
.video-wrap{width:100%;aspect-ratio:16/9;background:var(--accent-sub);border:1px solid var(--border);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;margin-bottom:32px;position:relative;overflow:hidden}
.video-icon{width:44px;height:44px;border-radius:50%;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center}
.video-icon svg{width:18px;height:18px;color:var(--text3)}
.video-label{font-size:13px;color:var(--text3);font-weight:500}
.video-badge{position:absolute;top:12px;left:12px;font-size:10px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);background:var(--surface);border:1px solid var(--border);padding:2px 8px;border-radius:4px}

/* DEFINITION BOX */
.def-box{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px 24px;margin-bottom:32px}
.def-box p{font-size:14px;color:var(--text2);line-height:1.7}
.def-box strong{color:var(--text)}

/* ACCORDION */
.acc-wrap{border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:32px}
.acc-item{border-bottom:1px solid var(--border)}
.acc-item:last-child{border-bottom:none}
.acc-q{width:100%;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:none;border:none;font-family:var(--font);font-size:14px;font-weight:500;color:var(--text);cursor:pointer;text-align:left;transition:background .1s}
.acc-q:hover{background:var(--bg)}
.acc-q svg{flex-shrink:0;width:15px;height:15px;color:var(--text3);transition:transform .2s}
.acc-item.open .acc-q svg{transform:rotate(180deg)}
.acc-a{display:none;padding:0 20px 16px;font-size:13px;color:var(--text2);line-height:1.7}
.acc-item.open .acc-a{display:block}
.acc-a ul{padding-left:16px;margin-top:6px}
.acc-a li{margin-bottom:4px}
.acc-a strong{color:var(--text)}

/* TAGS */
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:28px}
.tag{font-size:11px;font-weight:500;padding:3px 9px;border-radius:4px;border:1px solid var(--border);color:var(--text2)}
.tag.ind{border-color:#c7d2fe;background:#eef2ff;color:#4338ca}
.tag.grc{border-color:#fde68a;background:#fffbeb;color:#92400e}
.tag.ai{border-color:#bbf7d0;background:#f0fdf4;color:#166534}
body.dark .tag.ind{border-color:var(--indigo-sub);background:var(--indigo-sub);color:var(--indigo)}
body.dark .tag.grc{border-color:var(--amber-sub);background:var(--amber-sub);color:var(--amber)}
body.dark .tag.ai{border-color:var(--green-sub);background:var(--green-sub);color:var(--green)}

/* INFO PILL */
.info-pill{display:flex;gap:8px;padding:10px 14px;border-radius:var(--r);background:var(--indigo-sub);border:1px solid #c7d2fe;font-size:12px;color:#4338ca;line-height:1.5;margin-bottom:20px}
body.dark .info-pill{border-color:var(--indigo-sub);color:var(--indigo)}
.partner-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--r);background:var(--green-sub);border:1px solid #bbf7d0;font-size:12px;font-weight:600;color:var(--green);margin-bottom:20px}
body.dark .partner-badge{border-color:var(--green-sub)}

/* MOBILE */
.mob-sb-btn{display:none;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--text2);background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:6px 12px;cursor:pointer;margin-bottom:20px}
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);transition:transform .2s;z-index:150}
  .sidebar.open{transform:translateX(0)}
  .content{margin-left:0;padding:24px 20px}
  .mob-sb-btn{display:flex}
  .page-title{font-size:22px}
}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-left:var(--sb)}
.footer-contact{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text2)}
.footer-contact a{color:var(--text2);text-decoration:none;transition:color .15s}
.footer-contact a:hover{color:var(--text)}
.footer-contact svg{width:15px;height:15px;color:var(--text3)}
.footer-copy{font-size:12px;color:var(--text3)}
@media(max-width:768px){footer{margin-left:0}}
</style>

