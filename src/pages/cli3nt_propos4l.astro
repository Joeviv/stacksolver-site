<style>
:root{
  --bg:#fafafa;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#85a03a;--indigo-sub:#f4f7e9;
  --orange:#f97316;--orange-sub:#fff7ed;
  --green:#16a34a;--green-sub:#f0fdf4;
  --text:#18181b;--text2:#71717a;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,sans-serif;--max:760px;
}
body.dark{
  --bg:#0a0a0a;--surface:#111;--border:#27272a;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#18181b;--accent-sub:#27272a;
  --indigo:#a6c04d;--indigo-sub:#3d4418;
  --orange:#fb923c;--orange-sub:#431407;
  --green:#4ade80;--green-sub:#052e16;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;font-size:16px;line-height:1.6}
a{color:inherit;text-decoration:none}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:var(--bg);border-bottom:1px solid var(--border);height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 24px}
.logo{font-size:14px;font-weight:700;letter-spacing:-.3px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-r{display:flex;gap:8px;align-items:center}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);font-family:var(--font)}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.site-link{font-size:12px;color:var(--text2);border:1px solid var(--border);padding:4px 12px;border-radius:var(--r);transition:all .15s}
.site-link:hover{color:var(--text);border-color:var(--text3)}

/* CONTAINER */
.container{width:100%;max-width:var(--max);margin:0 auto;padding:0 24px}

/* HERO */
.hero{background:var(--accent);padding:80px 0 64px;color:var(--accent-fg)}
body.dark .hero{background:var(--surface);border-bottom:1px solid var(--border)}
.hero-tag{display:inline-block;font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--orange);border:1px solid rgba(249,115,22,.35);padding:4px 10px;border-radius:4px;margin-bottom:20px}
body.dark .hero-tag{color:var(--orange)}
.hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;line-height:1.15;letter-spacing:-.03em;color:var(--accent-fg);max-width:560px}
body.dark .hero h1{color:var(--text)}
.hero-sub{margin-top:16px;font-size:1.05rem;color:rgba(255,255,255,.7);max-width:500px;line-height:1.65}
body.dark .hero-sub{color:var(--text2)}
.hero-actions{margin-top:32px;display:flex;gap:12px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:var(--r);font-size:.875rem;font-weight:500;cursor:pointer;transition:opacity .15s,transform .1s;border:none;font-family:var(--font)}
.btn:hover{opacity:.88;transform:translateY(-1px)}
.btn-primary{background:var(--surface);color:var(--accent)}
body.dark .btn-primary{background:var(--indigo);color:#fff}
.btn-outline{background:transparent;color:rgba(255,255,255,.85);border:1px solid rgba(255,255,255,.25)}
.btn-outline:hover{border-color:rgba(255,255,255,.5)}
body.dark .btn-outline{color:var(--text2);border-color:var(--border)}

/* SECTIONS */
.section{padding:72px 0}
.section-alt{background:var(--bg)}
.sec-label{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:10px}
.divider-accent{width:32px;height:3px;background:var(--orange);border-radius:2px;margin:10px 0 24px}
h2{font-size:clamp(1.4rem,3vw,1.9rem);font-weight:700;line-height:1.25;letter-spacing:-.02em}
p{color:var(--text2);line-height:1.7}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:72px 1fr;gap:24px;align-items:start}
.avatar{width:72px;height:72px;border-radius:50%;background:var(--indigo-sub);display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:var(--indigo);flex-shrink:0;border:1px solid var(--border)}
.tag-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px}
.tag{font-size:11px;font-weight:500;padding:3px 9px;border-radius:4px;background:var(--accent-sub);border:1px solid var(--border);color:var(--text2)}

/* TRACK RECORD */
.exp-list{display:flex;flex-direction:column;gap:0}
.exp-item{padding:24px 0;border-bottom:1px solid var(--border)}
.exp-item:last-child{border-bottom:none}
.exp-company{font-size:.8rem;font-weight:600;color:var(--orange);letter-spacing:.02em;margin-bottom:4px}
.exp-meta{font-size:.78rem;color:var(--text3);margin-bottom:8px}
.exp-item h3{font-size:1rem;font-weight:600;color:var(--text);margin-bottom:6px}

/* SERVICES GRID */
.card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:22px;transition:border-color .15s}
.card:hover{border-color:var(--text3)}
.card-icon{font-size:1.3rem;margin-bottom:10px}
.card h3{font-size:.95rem;font-weight:600;color:var(--text);margin-bottom:6px}
.card p{font-size:.85rem}
.card-meta{font-size:.75rem;color:var(--text3);margin-top:10px;display:flex;gap:10px;flex-wrap:wrap}
.card-meta span::before{content:"· "}
.card-meta span:first-child::before{content:""}
.card--featured{border-color:var(--orange)}

/* ENGAGEMENT MODELS */
.model-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px}
.model-card{border:1px solid var(--border);border-radius:var(--r);padding:26px}
.model-card--featured{border-color:var(--orange)}
.model-label{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--orange);margin-bottom:6px}
.model-card h3{font-size:1.05rem;font-weight:600;color:var(--text);margin-bottom:8px}
.model-list{list-style:none;margin-top:12px}
.model-list li{font-size:.85rem;color:var(--text2);padding:5px 0;border-bottom:1px solid var(--border);display:flex;gap:8px}
.model-list li:last-child{border-bottom:none}
.model-list li::before{content:"→";color:var(--orange);flex-shrink:0}

/* CTA */
.cta-section{background:var(--accent);padding:80px 0}
body.dark .cta-section{background:var(--surface);border-top:1px solid var(--border)}
.cta-inner{text-align:center;max-width:500px;margin:0 auto}
.cta-inner h2{color:var(--accent-fg)}
body.dark .cta-inner h2{color:var(--text)}
.cta-inner p{color:rgba(255,255,255,.7);margin-top:10px}
body.dark .cta-inner p{color:var(--text2)}
.cta-inner .hero-actions{justify-content:center;margin-top:28px}
.cta-btn-main{background:var(--surface);color:var(--accent);padding:12px 24px;border-radius:var(--r);font-weight:600;font-size:.95rem;display:inline-flex;align-items:center;gap:8px;border:none;cursor:pointer;font-family:var(--font);transition:opacity .15s}
body.dark .cta-btn-main{background:var(--indigo);color:#fff}
.cta-btn-main:hover{opacity:.88}
.cta-btn-sec{background:transparent;color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.25);padding:12px 24px;border-radius:var(--r);font-size:.95rem;font-family:var(--font);cursor:pointer;transition:border-color .15s}
body.dark .cta-btn-sec{color:var(--text2);border-color:var(--border)}
.cta-btn-sec:hover{border-color:rgba(255,255,255,.5)}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.footer-p{font-size:.78rem;color:var(--text3)}

/* CONFIDENTIAL BANNER */
.conf-banner{background:var(--orange-sub);border:1px solid var(--orange);border-radius:var(--r);padding:10px 16px;font-size:.8rem;color:var(--orange);font-weight:500;margin-bottom:32px;display:flex;align-items:center;gap:8px}
body.dark .conf-banner{background:var(--orange-sub);color:var(--orange)}

@media(max-width:600px){
  .about-grid{grid-template-columns:1fr}
  .avatar{display:none}
  .section{padding:48px 0}
  .hero{padding:56px 0 48px}
}
</style>

