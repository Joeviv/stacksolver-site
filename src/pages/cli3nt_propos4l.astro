<script is:inline>
function toggleTheme(){
  document.body.classList.toggle('dark');
  const isDark=document.body.classList.contains('dark');
  document.getElementById('themeBtn').innerHTML=isDark
    ?'<svg width="14" height="14"><use href="#V-sun"/></svg>'
    :'<svg width="14" height="14"><use href="#V-moon"/></svg>';
}

function setLang(l){
  document.documentElement.lang=l;
  document.querySelectorAll('.lb').forEach(b=>b.classList.toggle('on',b.textContent===l.toUpperCase()));
  document.querySelectorAll('[data-es],[data-en]').forEach(el=>{
    const v=el.getAttribute('data-'+l);if(v)el.innerHTML=v;
  });
  try{localStorage.setItem('lang',l);}catch(e){}
}
try{var __ss_l=localStorage.getItem('lang');if(__ss_l==='en'&&typeof setLang==='function')setLang('en');}catch(e){}
</script>
