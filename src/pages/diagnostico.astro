<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagnóstico ERP, GRC e IA Local — StackSolver</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#fafafa;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-subtle:#f4f4f5;
  --indigo:#6366f1;--indigo-sub:#eef2ff;
  --green:#16a34a;--green-sub:#f0fdf4;
  --amber:#d97706;--amber-sub:#fffbeb;
  --text:#18181b;--text2:#71717a;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
}
body.dark{
  --bg:#0a0a0a;--surface:#111;--border:#27272a;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#18181b;--accent-subtle:#27272a;
  --indigo:#818cf8;--indigo-sub:#1e1b4b;
  --green:#4ade80;--green-sub:#052e16;
  --amber:#fbbf24;--amber-sub:#1c1400;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased;transition:background .2s,color .2s}
nav{position:fixed;top:0;left:0;right:0;z-index:100;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:var(--bg);border-bottom:1px solid var(--border)}
.logo{font-size:14px;font-weight:700;letter-spacing:-.3px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-r{display:flex;gap:6px;align-items:center}
.icon-btn{width:32px;height:32px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);transition:all .15s}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:4px 11px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.wrap{max-width:720px;margin:0 auto;padding:72px 20px 80px}
.steps{display:flex;align-items:center;margin-bottom:32px}
.step{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;position:relative}
.step:not(:last-child)::after{content:'';position:absolute;top:11px;left:calc(50% + 13px);width:calc(100% - 26px);height:1px;background:var(--border)}
.step.done:not(:last-child)::after{background:var(--indigo)}
.step-n{width:24px;height:24px;border-radius:50%;font-size:10px;font-weight:700;border:1px solid var(--border);background:var(--bg);color:var(--text3);display:flex;align-items:center;justify-content:center;position:relative;z-index:1;transition:all .2s}
.step.on .step-n{border-color:var(--indigo);background:var(--indigo-sub);color:var(--indigo)}
.step.done .step-n{border-color:var(--green);background:var(--green-sub);color:var(--green)}
.step-l{font-size:10px;font-weight:500;color:var(--text3);white-space:nowrap}
.step.on .step-l{color:var(--text2)}
.step.done .step-l{color:var(--green)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:36px;animation:up .25s ease}
@keyframes up{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.eyebrow{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:10px}
.eyebrow.ind{color:var(--indigo)}
h1.t{font-size:28px;font-weight:800;letter-spacing:-.6px;line-height:1.2;margin-bottom:8px}
h2.t{font-size:22px;font-weight:700;letter-spacing:-.4px;line-height:1.25;margin-bottom:8px}
.sub{font-size:14px;color:var(--text2);line-height:1.6;margin-bottom:24px}
.sub strong{color:var(--text);font-weight:600}
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;border:1px solid transparent;font-family:var(--font);transition:all .15s;white-space:nowrap}
.btn:disabled{opacity:.35;cursor:not-allowed;pointer-events:none}
.btn-dark{background:var(--accent);color:var(--accent-fg);border-color:var(--accent)}
.btn-dark:hover{opacity:.85}
.btn-out{background:none;border-color:var(--border);color:var(--text2)}
.btn-out:hover{border-color:var(--text3);color:var(--text)}
.btn-ghost{background:none;border:none;color:var(--text2);padding:9px 12px}
.btn-ghost:hover{color:var(--text)}
.btn-green{background:var(--green);color:#fff;border-color:var(--green)}
.btn-row{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;padding-top:20px;border-top:1px solid var(--border);margin-top:28px}
.hint{font-size:12px;color:var(--text3)}
.feat-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:28px}
.feat{background:var(--surface);padding:16px}
.feat-ico{width:28px;height:28px;border-radius:6px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.feat-ico svg{width:14px;height:14px;color:var(--text2)}
.feat strong{display:block;font-size:13px;font-weight:600;margin-bottom:3px}
.feat span{font-size:12px;color:var(--text2);line-height:1.5}
.badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:500;color:var(--text2);background:var(--accent-subtle);border:1px solid var(--border);padding:4px 10px;border-radius:20px;margin-bottom:20px}
.div{display:flex;align-items:center;gap:10px;margin:28px 0 18px}
.div-line{flex:1;height:1px;background:var(--border)}
.div-txt{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text3);white-space:nowrap}
.how-h{font-size:16px;font-weight:700;letter-spacing:-.2px;margin-bottom:4px}
.how-sub{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:16px}
.tab-row{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px}
.tab{padding:8px 16px;font-size:13px;font-weight:500;color:var(--text2);background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-1px;cursor:pointer;font-family:var(--font);transition:all .15s}
.tab:hover{color:var(--text)}
.tab.on{color:var(--text);border-bottom-color:var(--text);font-weight:600}
.panel{display:none;animation:up .2s ease}
.panel.on{display:block}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:12px}
.hc{padding:16px;border:1px solid var(--border);border-radius:var(--r);background:var(--bg)}
.hc-ico{width:30px;height:30px;border-radius:6px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin-bottom:10px}
.hc-ico svg{width:15px;height:15px;color:var(--text)}
.hc h4{font-size:13px;font-weight:600;margin-bottom:4px}
.hc p{font-size:12px;color:var(--text2);line-height:1.5}
.mods-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px}
.mi{padding:12px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface)}
.mi-ico{width:26px;height:26px;border-radius:6px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.mi-ico svg{width:13px;height:13px;color:var(--text2)}
.mi strong{display:block;font-size:11px;font-weight:600;margin-bottom:2px}
.mi span{font-size:10px;color:var(--text3);line-height:1.4}
.info-strip{display:flex;gap:8px;padding:12px 14px;border-radius:var(--r);background:var(--accent-subtle);border:1px solid var(--border);font-size:12px;color:var(--text2);line-height:1.5}
.info-strip strong{color:var(--text)}
.grc3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
.gp{padding:16px;border:1px solid var(--border);border-radius:var(--r);text-align:center}
.gp-ico{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
.gp h4{font-size:12px;font-weight:700;margin-bottom:4px}
.gp p{font-size:11px;color:var(--text2);line-height:1.5}
.gov .gp-ico{background:var(--indigo-sub)} .gov .gp-ico svg{color:var(--indigo)}
.risk .gp-ico{background:var(--amber-sub)} .risk .gp-ico svg{color:var(--amber)}
.comp .gp-ico{background:var(--green-sub)} .comp .gp-ico svg{color:var(--green)}
.alert{display:flex;gap:8px;padding:12px 14px;border-radius:var(--r);background:var(--amber-sub);border:1px solid #fde68a;font-size:12px;color:#92400e;line-height:1.5}
body.dark .alert{color:var(--amber);border-color:var(--amber-sub)}
.proc{display:flex;gap:0;margin:14px 0 12px}
.ps{flex:1;text-align:center;position:relative;padding:0 4px}
.ps:not(:last-child)::after{content:'›';position:absolute;right:-8px;top:8px;font-size:14px;color:var(--text3)}
.psn{width:22px;height:22px;border-radius:50%;background:var(--accent-subtle);border:1px solid var(--border);font-size:10px;font-weight:700;color:var(--text);display:flex;align-items:center;justify-content:center;margin:0 auto 4px}
.psl{font-size:10px;color:var(--text2);line-height:1.3}
.chips{display:flex;flex-wrap:wrap;gap:5px;margin-top:10px}
.chip{font-size:11px;font-weight:500;padding:2px 8px;border-radius:4px;border:1px solid var(--border);color:var(--text3)}
.re-box{display:flex;gap:8px;padding:10px 14px;border-radius:var(--r);background:var(--green-sub);border:1px solid #bbf7d0;font-size:12px;color:var(--text2);line-height:1.5;margin-bottom:14px}
body.dark .re-box{border-color:var(--green-sub)}
.faq-list{border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:20px}
.faq-item{border-bottom:1px solid var(--border)}
.faq-item:last-child{border-bottom:none}
.faq-q{width:100%;display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:none;border:none;font-family:var(--font);font-size:13px;font-weight:500;color:var(--text);cursor:pointer;text-align:left}
.faq-q:hover{background:var(--bg)}
.faq-q svg{flex-shrink:0;transition:transform .2s;color:var(--text3)}
.faq-item.open .faq-q svg{transform:rotate(180deg)}
.faq-a{display:none;padding:0 16px 14px;font-size:13px;color:var(--text2);line-height:1.6}
.faq-item.open .faq-a{display:block}
.og{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:24px}
.opt{padding:14px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;transition:all .15s;position:relative;background:var(--surface)}
.opt:hover{border-color:var(--text3)}
.opt.sel{border:2px solid var(--border-strong)}
.opt-ck{position:absolute;top:8px;right:8px;width:16px;height:16px;border-radius:4px;background:var(--accent);display:none;align-items:center;justify-content:center}
.opt-ck svg{width:9px;height:9px;color:var(--accent-fg)}
.opt.sel .opt-ck{display:flex}
.opt-ico{width:26px;height:26px;border-radius:6px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.opt-ico svg{width:13px;height:13px;color:var(--text2)}
.opt strong{display:block;font-size:12px;font-weight:600;margin-bottom:2px}
.opt span{font-size:10px;color:var(--text3);line-height:1.4}
.opt.sel span{color:var(--text2)}
.pl{display:flex;flex-direction:column;gap:6px;margin-bottom:24px}
.pain{display:flex;align-items:flex-start;gap:10px;padding:14px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;transition:all .15s;background:var(--surface)}
.pain:hover{border-color:var(--text3)}
.pain.sel{border:2px solid var(--border-strong)}
.pcb{width:18px;height:18px;border-radius:4px;border:1px solid var(--border);background:var(--bg);flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center}
.pain.sel .pcb{background:var(--accent);border-color:var(--accent)}
.pcb svg{width:9px;height:9px;color:var(--accent-fg);display:none}
.pain.sel .pcb svg{display:block}
.pt{flex:1}
.pt strong{display:block;font-size:13px;font-weight:600;margin-bottom:2px}
.pt span{font-size:11px;color:var(--text2);line-height:1.5}
.ptag{font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;align-self:flex-start;margin-top:1px;flex-shrink:0;border:1px solid var(--border);color:var(--text3)}
.tag-e{border-color:#c7d2fe;background:#eef2ff;color:#4338ca}
.tag-g{border-color:#fde68a;background:#fffbeb;color:#92400e}
.tag-a{border-color:#bbf7d0;background:#f0fdf4;color:#166534}
.tag-w{border-color:#fce7f3;background:#fdf2f8;color:#9d174d}
body.dark .tag-e{border-color:var(--indigo-sub);background:var(--indigo-sub);color:var(--indigo)}
body.dark .tag-g{border-color:var(--amber-sub);background:var(--amber-sub);color:var(--amber)}
body.dark .tag-a{border-color:var(--green-sub);background:var(--green-sub);color:var(--green)}
body.dark .tag-w{color:#f9a8d4;border-color:#831843;background:#500724}
.mg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px}
.mc{padding:16px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;transition:all .15s;background:var(--surface);position:relative;display:flex;align-items:flex-start;gap:12px}
.mc:hover{border-color:var(--text3)}
.mc.sel{border:2px solid var(--border-strong)}
.mc-ico{width:34px;height:34px;border-radius:8px;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mc-ico svg{width:17px;height:17px;color:var(--text2)}
.mc-b{flex:1}
.mc-b strong{display:block;font-size:13px;font-weight:600;margin-bottom:3px}
.mc-b span{font-size:11px;color:var(--text2);line-height:1.5}
.mbadge{position:absolute;top:10px;right:10px;font-size:9px;font-weight:600;padding:2px 6px;border-radius:4px;border:1px solid var(--border);color:var(--text3)}
.mb-p{border-color:#c7d2fe;background:#eef2ff;color:#4338ca}
.mb-n{border-color:#bbf7d0;background:#f0fdf4;color:#166534}
body.dark .mb-p{border-color:var(--indigo-sub);background:var(--indigo-sub);color:var(--indigo)}
body.dark .mb-n{border-color:var(--green-sub);background:var(--green-sub);color:var(--green)}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.ff{grid-column:1/-1}
.field label{display:block;font-size:11px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:var(--r);background:var(--bg);color:var(--text);font-size:13px;font-family:var(--font);outline:none;transition:border .15s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--text3)}
.field input::placeholder{color:var(--text3)}
.field textarea{resize:vertical;min-height:72px}
.field select option{background:var(--surface);color:var(--text)}
.priv{display:flex;gap:8px;padding:12px 14px;border-radius:var(--r);background:var(--green-sub);border:1px solid #bbf7d0;font-size:12px;color:var(--text2);line-height:1.5;margin-top:4px}
body.dark .priv{border-color:var(--green-sub)}
.rt{text-align:center;margin-bottom:28px}
.sr{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;width:80px;height:80px;border-radius:50%;border:2px solid var(--green);background:var(--green-sub);margin-bottom:12px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.15)}50%{box-shadow:0 0 0 10px rgba(22,163,74,0)}}
.sn{font-size:26px;font-weight:800;color:var(--green);line-height:1}
.sl{font-size:9px;font-weight:700;color:var(--green);letter-spacing:1px}
.rg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px}
.rc{padding:16px;border:1px solid var(--border);border-radius:var(--r)}
.rc.pri{border-color:var(--indigo);background:var(--indigo-sub)}
.rcp{font-size:10px;font-weight:700;letter-spacing:.8px;color:var(--indigo);margin-bottom:4px}
.rct{font-size:14px;font-weight:700;margin-bottom:4px}
.rcd{font-size:12px;color:var(--text2);line-height:1.5}
.rcl{display:flex;align-items:center;gap:6px;margin-top:8px;font-size:11px;color:var(--text3)}
.tb{flex:1;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.tf{height:100%;background:var(--indigo);animation:fill 1s .3s ease both}
@keyframes fill{from{width:0}to{width:var(--w,60%)}}
.ract{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:24px}
.ib{display:flex;gap:8px;padding:12px 14px;border-radius:var(--r);background:var(--accent-subtle);border:1px solid var(--border);font-size:12px;color:var(--text2);line-height:1.5;margin-bottom:16px}
.ctr{font-size:12px;color:var(--text3)}
.ctr b{color:var(--indigo)}
/* HAMBURGER NAV */
.hamburger{display:none;width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;align-items:center;justify-content:center;color:var(--text2);transition:all .15s;flex-shrink:0}
.mob-menu{display:none;position:fixed;top:52px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:12px 16px 16px;flex-direction:column;gap:2px;z-index:199;box-shadow:0 8px 24px rgba(0,0,0,.08)}
body.dark .mob-menu{box-shadow:0 8px 24px rgba(0,0,0,.35)}
.mob-menu.open{display:flex}
.mob-link{font-size:15px;font-weight:500;color:var(--text2);padding:10px 12px;border-radius:var(--r);transition:all .15s;text-decoration:none;display:block}
.mob-link:hover,.mob-link.on{color:var(--text);background:var(--accent-subtle)}
.mob-lang-row{display:flex;align-items:center;justify-content:space-between;padding:6px 12px 2px}
.mob-lang-lbl{font-size:12px;color:var(--text3)}
@media(max-width:768px){
  .nav-desktop a:not(.logo){display:none!important}
  .hamburger{display:flex}
  .lang-wrap{display:none}
}
@media(max-width:600px){
  .og{grid-template-columns:1fr 1fr}
  .mg{grid-template-columns:1fr}
  .feat-row{grid-template-columns:1fr}
  .fg{grid-template-columns:1fr}
  .rg{grid-template-columns:1fr}
  .grc3,.g3,.mods-strip{grid-template-columns:1fr 1fr}
  .card{padding:24px}
  .proc{flex-wrap:wrap;gap:8px}
  .ps:not(:last-child)::after{display:none}
  .tab{padding:8px 10px;font-size:12px}
}

footer{border-top:1px solid var(--border);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;max-width:760px;margin:0 auto}
.fc{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text2)}
.fc a{color:var(--text2);text-decoration:none}
.fc a:hover{color:var(--text)}
.fc svg{width:14px;height:14px;color:var(--text3)}
</style>

