<script is:inline>
const S={lang:'es',theme:'light',ind:null,pains:[],mods:[],cur:0};
function toggleTheme(){
  S.theme=S.theme==='light'?'dark':'light';
  document.body.classList.toggle('dark',S.theme==='dark');
  document.getElementById('themeBtn').innerHTML=S.theme==='dark'?'<svg width="15" height="15"><use href="#I-sun"/></svg>':'<svg width="15" height="15"><use href="#I-moon"/></svg>';
}
function setLang(l){
  S.lang=l;
  document.querySelectorAll('.lb').forEach(b=>b.classList.toggle('on',b.textContent===l.toUpperCase()));
  document.querySelectorAll('[data-es],[data-en]').forEach(el=>{const v=el.getAttribute('data-'+l);if(v)el.innerHTML=v;});
}
function showTab(i){
  document.querySelectorAll('.tab').forEach((t,j)=>t.classList.toggle('on',i===j));
  document.querySelectorAll('.panel').forEach((p,j)=>p.classList.toggle('on',i===j));
}
function togFaq(btn){
  const item=btn.parentElement,was=item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(f=>f.classList.remove('open'));
  if(!was)item.classList.add('open');
}
function goTo(n){
  document.getElementById('p'+S.cur).style.display='none';
  for(let i=0;i<6;i++){const d=document.getElementById('s'+i);d.classList.remove('on','done');if(i<n)d.classList.add('done');}
  document.getElementById('s'+n).classList.add('on');
  S.cur=n;
  document.getElementById('p'+n).style.display='block';
  window.scrollTo({top:60,behavior:'smooth'});
  if(n===5)buildResult();
}
function pickInd(el){
  document.querySelectorAll('#indGrid .opt').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');S.ind=el.dataset.v;
  document.getElementById('b1').disabled=false;
  document.getElementById('indCtr').innerHTML='<b>✓</b> '+el.querySelector('strong').textContent;
}
function togPain(el){
  el.classList.toggle('sel');const v=el.dataset.v;
  if(el.classList.contains('sel')){if(!S.pains.includes(v))S.pains.push(v);}else S.pains=S.pains.filter(x=>x!==v);
  const n=S.pains.length;
  document.getElementById('painCtr').innerHTML=n>0?'<b>'+n+'</b> '+(S.lang==='es'?'seleccionado'+(n>1?'s':''):'selected'):(S.lang==='es'?'Seleccione al menos uno':'Select at least one');
  document.getElementById('b2').disabled=n===0;
}
function togMod(el){
  el.classList.toggle('sel');const v=el.dataset.v;
  if(el.classList.contains('sel')){if(!S.mods.includes(v))S.mods.push(v);}else S.mods=S.mods.filter(x=>x!==v);
  const n=S.mods.length;
  document.getElementById('modCtr').innerHTML=n>0?'<b>'+n+'</b> '+(S.lang==='es'?'seleccionado'+(n>1?'s':''):'selected'):(S.lang==='es'?'Seleccione al menos uno':'Select at least one');
  document.getElementById('b3').disabled=n===0;
}
function valEmail(){document.getElementById('b4').disabled=!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(document.getElementById('fe').value);}
function doSubmit(){
  const em=document.getElementById('fe').value;
  document.getElementById('confEmail').innerHTML=S.lang==='es'?'Resumen enviado a <strong>'+em+'</strong>. El equipo de StackSolver le contactará en menos de 24 horas hábiles.':'Summary sent to <strong>'+em+'</strong>. The StackSolver team will contact you within 24 business hours.';
  goTo(5);
}
function buildResult(){document.getElementById('scoreN').textContent=Math.min(68+S.pains.length*3+S.mods.length*2,99);}
function resetAll(){S.ind=null;S.pains=[];S.mods=[];document.querySelectorAll('.opt,.pain,.mc').forEach(e=>e.classList.remove('sel'));['b1','b2','b3','b4'].forEach(id=>document.getElementById(id).disabled=true);}
document.getElementById('s0').classList.add('on');
// ── MOBILE MENU ──
function toggleMobileMenu(){
  const m=document.getElementById('mobMenu');
  const open=m.classList.toggle('open');
  document.getElementById('hambBtn').innerHTML=open
    ?'<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'
    :'<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>';
}
document.addEventListener('click',function(e){
  const m=document.getElementById('mobMenu');
  const b=document.getElementById('hambBtn');
  if(m&&m.classList.contains('open')&&!m.contains(e.target)&&b&&!b.contains(e.target)){
    m.classList.remove('open');
    b.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>';
  }
});
</script>

