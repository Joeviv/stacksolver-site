---
import ProductPageLayout from '../layouts/ProductPageLayout.astro';

const pageTitle = "Estrategia Digital Integral | Construimos tu Futuro Tecnológico - Stacksolver.tech";
const serviceName = "Construimos tu Hoja de Ruta Tecnológica";
const leadParagraph = "La tecnología sin una estrategia es solo un gasto. Actuamos como tu socio estratégico para diseñar, implementar y evolucionar un ecosistema digital que no solo resuelve problemas hoy, sino que impulsa tu crecimiento y te prepara para el mañana.";

const strategyFeatures = [
  {
    id: "ed-diagnosis",
    name: "Diagnóstico 360°: Entender para Construir",
    description: "Analizamos tu negocio, procesos y metas para crear un mapa claro de tus desafíos y oportunidades tecnológicas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12a.75.75 0 01.75-.75h.008v.001M3.75 12a.75.75 0 00-.75.75h.008v-.001M19.5 12a.75.75 0 01.75-.75h.008v.001M19.5 12a.75.75 0 00-.75.75h.008v-.001M12 19.5a.75.75 0 01.75-.75h.008v.001M12 19.5a.75.75 0 00-.75.75h.008v-.001M12 4.5a.75.75 0 01.75-.75h.008v.001M12 4.5a.75.75 0 00-.75.75h.008v-.001M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/strategy-diagnosis.jpg' },
    descriptiveText: "Nuestra consultoría comienza con una inmersión profunda. A través de talleres y análisis, entendemos tu visión, tu operación y tu mercado. El resultado es un diagnóstico claro que sirve como la base sólida para todas las decisiones tecnológicas futuras, asegurando que cada paso que demos esté alineado con tus objetivos de negocio."
  },
  {
    id: "ed-stack",
    name: "Arquitectura a Medida: Tu 'Stack Tecnológico' Ideal",
    description: "Diseñamos la combinación perfecta de herramientas y plataformas que se alinea con tu estrategia y presupuesto.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6A1.125 1.125 0 012.25 10.875v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/strategy-stack.jpg' },
    descriptiveText: "Este es nuestro enfoque 'Stack Solver'. No forzamos una herramienta, construimos una solución. Seleccionamos y combinamos las tecnologías más adecuadas —sean desarrollos a medida con FileMaker, webs ultrarrápidas con Astro, o plataformas LMS con Moodle— para crear una arquitectura tecnológica que es potente, escalable y, sobre todo, tuya."
  },
  {
    id: "ed-implementation",
    name: "Implementación Ágil y Centrada en el Valor",
    description: "Desarrollamos e integramos las soluciones de forma iterativa, entregando valor tangible en cada fase del proyecto.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21V3M4.685 15.345a9.004 9.004 0 01-1.423-4.582M19.315 15.345a9.004 9.004 0 00-1.423-4.582" /></svg>`,
    media: { type: 'localVideo', src: '/videos/features/strategy-agile.mp4' },
    descriptiveText: "Olvídate de los proyectos de 'caja negra' que duran meses sin resultados visibles. Trabajamos con metodologías ágiles, dividiendo el proyecto en sprints y entregando funcionalidades operativas de forma regular. Esto te permite dar feedback constante y asegura que el producto final esté perfectamente alineado con tus expectativas."
  },
  {
    id: "ed-evolution",
    name: "Optimización y Evolución Continua",
    description: "El lanzamiento es solo el comienzo. Te ayudamos a monitorear, optimizar y evolucionar tu tecnología para mantener la competitividad.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
    media: { type: 'localImage', src: '/images/features/strategy-evolution.jpg' },
    descriptiveText: "El mercado no se detiene, y tu tecnología tampoco debería. Establecemos métricas de rendimiento, analizamos los datos de uso y te proponemos mejoras continuas para asegurar que tu inversión tecnológica no se vuelva obsoleta, sino que evolucione y se adapte junto a tu negocio."
  },
  {
    id: "ed-adoption",
    name: "Capacitación y Gestión del Cambio",
    description: "Aseguramos que tu equipo adopte las nuevas herramientas, maximizando el impacto y el retorno de tu inversión.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m-7.5-2.928A9.09 9.09 0 005.25 18.72m-8.384-2.88a3 3 0 014.682-2.72m-12.122.992A9.09 9.09 0 013.75 18.72m12.54-1.665a9.094 9.094 0 01-3.742-.479m-8.383-2.928a9.09 9.09 0 013.742-.479M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/strategy-adoption.jpg' },
    descriptiveText: "La mejor herramienta del mundo es inútil si nadie sabe cómo usarla. Parte de nuestra estrategia es un plan de gestión del cambio que incluye capacitación, documentación y soporte, asegurando que tu equipo no solo utilice la nueva tecnología, sino que la abrace como una mejora a su trabajo diario."
  }
];

const featureSections = [
    {
        title: "Nuestra Metodología Estratégica",
        features: strategyFeatures
    }
];
---

<ProductPageLayout
  pageTitle={pageTitle}
  serviceName={serviceName}
  leadParagraph={leadParagraph}
  featureSections={featureSections}
/>