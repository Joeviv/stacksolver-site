<script is:inline>
// ── THEME ──
function toggleTheme(){
  document.body.classList.toggle('dark');
  const d=document.body.classList.contains('dark');
  document.getElementById('themeBtn').innerHTML=d?'<svg width="14" height="14"><use href="#H-sun"/></svg>':'<svg width="14" height="14"><use href="#H-moon"/></svg>';
  drawMap();
}
// ── LANG ──
function setLang(l){
  document.documentElement.lang=l;
  document.querySelectorAll('.lb').forEach(b=>b.classList.toggle('on',b.textContent===l.toUpperCase()));
  document.querySelectorAll('[data-es],[data-en]').forEach(el=>{const v=el.getAttribute('data-'+l);if(v)el.innerHTML=v;});
}

// ── COUNTER ANIMATION ──
function countUp(el,target,suffix,duration){
  const start=Date.now();
  const step=()=>{
    const p=Math.min((Date.now()-start)/duration,1);
    const val=Math.round(p*target);
    el.textContent=val+suffix;
    if(p<1)requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}
window.addEventListener('load',()=>{
  setTimeout(()=>{
    countUp(document.getElementById('cn1'),247,'',1200);
    countUp(document.getElementById('cn2'),38,'',1000);
    countUp(document.getElementById('cn3'),98,'%',1400);
  },600);
});

// ── WORLD MAP (Canvas) ──
function drawMap(){
  const canvas=document.getElementById('worldMap');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const dark=document.body.classList.contains('dark');
  ctx.clearRect(0,0,W,H);

  ctx.fillStyle=dark?'#0d0d0d':'#f5f5f7';
  ctx.fillRect(0,0,W,H);

  // Projection: lon/lat → canvas pixel
  const p=([lo,la])=>[(lo+180)/360*W,(90-la)/180*H];

  // Ray-casting point-in-polygon
  function pip(pt,poly){
    let r=false,n=poly.length;
    for(let i=0,j=n-1;i<n;j=i++){
      const[xi,yi]=p(poly[i]);const[xj,yj]=p(poly[j]);
      if((yi>pt[1])!=(yj>pt[1])&&pt[0]<(xj-xi)*(pt[1]-yi)/(yj-yi)+xi)r=!r;
    }
    return r;
  }

  // ── Continent polygons (lon/lat pairs) ──
  // North + Central America
  const NA=[[-168,54],[-162,60],[-148,61],[-140,59],[-136,57],[-130,55],[-126,50],[-124,48],[-118,34],[-117,32],[-110,23],[-106,19],[-104,19],[-100,17],[-97,16],[-90,14],[-84,11],[-80,8],[-77,8],[-83,10],[-84,16],[-88,16],[-90,16],[-90,21],[-87,21],[-97,22],[-97,26],[-90,29],[-87,30],[-84,30],[-82,29],[-81,25],[-77,35],[-74,41],[-70,43],[-65,44],[-62,47],[-54,47],[-57,51],[-62,58],[-68,63],[-73,65],[-78,63],[-82,64],[-86,68],[-100,72],[-115,73],[-126,73],[-140,70],[-156,72],[-163,71],[-163,65],[-168,54]];
  // South America
  const SA=[[-77,8],[-75,11],[-70,12],[-62,11],[-60,9],[-52,4],[-50,2],[-47,1],[-43,3],[-36,-5],[-35,-10],[-38,-15],[-40,-22],[-43,-23],[-48,-28],[-52,-33],[-55,-34],[-57,-38],[-62,-42],[-65,-46],[-65,-50],[-68,-55],[-75,-55],[-74,-52],[-72,-48],[-72,-38],[-71,-30],[-70,-22],[-70,-18],[-76,-14],[-77,-9],[-78,-5],[-80,0],[-80,8],[-77,8]];
  // Europe (Atlantic + Scandinavian + Baltic coast, Mediterranean simplified)
  const EU=[[-9,36],[-9,43],[-5,44],[-2,44],[0,48],[2,51],[3,52],[5,53],[8,55],[10,57],[5,60],[5,62],[8,65],[15,66],[25,71],[28,71],[30,65],[30,62],[28,60],[25,58],[24,56],[22,54],[18,55],[15,55],[12,55],[10,57],[8,55],[3,52],[2,52],[0,47],[-3,47],[-2,44],[-9,43],[-9,38],[-9,36]];
  // Eurasia main (Russia, Turkey, China, SE Asia — India and Arabia separate)
  const AS=[[28,38],[28,37],[36,37],[40,38],[42,42],[46,48],[50,48],[54,52],[58,56],[62,60],[65,68],[70,73],[80,73],[90,73],[100,72],[115,73],[130,72],[140,70],[150,70],[160,72],[170,67],[170,62],[163,54],[152,46],[145,44],[142,50],[140,46],[135,46],[132,43],[130,37],[128,35],[122,31],[121,24],[110,20],[108,10],[104,2],[100,4],[98,5],[96,8],[90,22],[86,20],[80,10],[72,22],[68,23],[62,22],[58,25],[56,24],[50,26],[46,30],[44,33],[40,37],[36,35],[36,32],[34,30],[32,30],[34,32],[36,37],[28,37],[28,38]];
  // India subcontinent
  const IN=[[68,23],[72,22],[76,8],[80,8],[80,16],[75,22],[68,23]];
  // Arabian Peninsula
  const ARAB=[[32,30],[36,24],[38,14],[43,12],[45,14],[50,16],[58,22],[56,24],[55,26],[52,26],[50,28],[47,30],[44,32],[40,33],[36,29],[32,30]];
  // Africa
  const AF=[[-5,35],[5,37],[10,37],[15,38],[25,37],[32,32],[37,22],[43,12],[50,10],[52,5],[45,-1],[40,-5],[36,-18],[34,-25],[30,-35],[18,-34],[16,-30],[12,-18],[10,-8],[0,5],[-5,10],[-17,15],[-18,28],[-5,35]];
  // Australia
  const AU=[[114,-22],[116,-32],[122,-34],[130,-35],[137,-35],[140,-38],[150,-38],[154,-28],[154,-22],[145,-18],[140,-18],[136,-12],[130,-12],[122,-18],[114,-22]];
  // Greenland
  const GL=[[-74,76],[-68,83],[-20,84],[-18,78],[-25,71],[-45,61],[-55,63],[-65,66],[-74,76]];
  // Great Britain
  const UK=[[-6,58],[-2,60],[0,58],[-1,55],[-3,55],[-5,56],[-6,58]];
  // Japan (Honshu)
  const JP=[[131,32],[133,35],[136,36],[140,38],[140,41],[137,40],[131,35],[131,32]];
  // New Zealand
  const NZ1=[[168,-45],[170,-40],[174,-38],[174,-42],[170,-46],[168,-45]];
  const NZ2=[[172,-34],[176,-36],[176,-38],[172,-36],[172,-34]];

  const hlPolys=[NA,SA,EU];
  const baseLand=[AS,IN,ARAB,AF,AU,GL,UK,JP,NZ1,NZ2];

  // ── Dot-matrix rendering ──
  const step=5, r=1.3;
  const dotHL=dark?'rgba(99,102,241,.72)':'rgba(79,70,229,.5)';
  const dotBase=dark?'rgba(255,255,255,.14)':'rgba(0,0,0,.16)';

  for(let x=step*.5;x<W;x+=step){
    for(let y=step*.5;y<H;y+=step){
      let hl=false,land=false;
      for(const poly of hlPolys){if(pip([x,y],poly)){hl=true;land=true;break;}}
      if(!hl)for(const poly of baseLand){if(pip([x,y],poly)){land=true;break;}}
      if(!land)continue;
      ctx.beginPath();
      ctx.arc(x,y,r,0,Math.PI*2);
      ctx.fillStyle=hl?dotHL:dotBase;
      ctx.fill();
    }
  }

  // ── City dots ──
  const cities=[[-74,4.7],[-74,40.7],[-87.6,41.9],[-79.4,43.7],[-0.1,51.5],[2.3,48.9],[-43.2,-22.9],[-58.4,-34.6]];
  cities.forEach(pos=>{
    const[cx,cy]=p(pos);
    ctx.beginPath();ctx.arc(cx,cy,6,0,Math.PI*2);
    ctx.fillStyle=dark?'rgba(99,102,241,.15)':'rgba(99,102,241,.12)';ctx.fill();
    ctx.beginPath();ctx.arc(cx,cy,3,0,Math.PI*2);
    ctx.fillStyle='#6366f1';ctx.fill();
  });

  // ── Connection arcs ──
  const arcs=[[[-74,4.7],[-0.1,51.5]],[[-74,4.7],[-74,40.7]],[[-74,40.7],[-0.1,51.5]]];
  arcs.forEach(([a,b])=>{
    const[ax,ay]=p(a);const[bx,by]=p(b);
    ctx.beginPath();ctx.moveTo(ax,ay);
    ctx.quadraticCurveTo((ax+bx)/2,(ay+by)/2-40,bx,by);
    ctx.strokeStyle=dark?'rgba(99,102,241,.3)':'rgba(99,102,241,.22)';
    ctx.lineWidth=1;ctx.setLineDash([3,4]);ctx.stroke();ctx.setLineDash([]);
  });

  // ── Region labels ──
  [['LATINOAMÉRICA',[-60,-15]],['USA & CANADÁ',[-100,50]],['EUROPA',[15,55]]].forEach(([txt,pos])=>{
    const[lx,ly]=p(pos);
    ctx.font='bold 9px "Inter",sans-serif';
    ctx.fillStyle=dark?'rgba(129,140,248,.8)':'rgba(79,70,229,.7)';
    ctx.textAlign='center';ctx.fillText(txt,lx,ly);
  });
}

// ── SCROLL FADE-IN ──
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
},{threshold:0.1});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

// ── INIT ──
window.addEventListener('load',()=>{
  drawMap();
});

// Duplicate marquee for infinite scroll
const track=document.getElementById('marqueeTrack');
if(track){const clone=track.cloneNode(true);track.parentNode.appendChild(clone);}
// ── MOBILE MENU ──
function toggleMobileMenu(){
  const m=document.getElementById('mobMenu');
  const open=m.classList.toggle('open');
  document.getElementById('hambBtn').innerHTML=open
    ?'<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'
    :'<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>';
}
document.addEventListener('click',function(e){
  const m=document.getElementById('mobMenu');
  const b=document.getElementById('hambBtn');
  if(m&&m.classList.contains('open')&&!m.contains(e.target)&&b&&!b.contains(e.target)){
    m.classList.remove('open');
    b.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>';
  }
});
</script>
</body>
</html>