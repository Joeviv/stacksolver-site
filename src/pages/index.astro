---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import ServiceDetail from '../components/ServiceDetail.astro';
import { servicesData } from '../data/services';

const pageTitle = "Stacksolver.tech: Soluciones a tu Medida.";
const pageDescription = "Creamos soluciones tecnológicas modernas: IA local y segura, desarrollo a medida, diseño web de alto rendimiento y plataformas de aprendizaje.";

const servicesForGrid = servicesData.map(s => ({
  id: s.id,
  displayTitle: s.displayTitle,
  subtitle: s.subtitle,
  previewImageUrl: s.previewImageUrl,
  link: "#"
}));
---
<BaseLayout title={pageTitle} description={pageDescription}>

  <HeroSection />

  <section class="services-section-wrapper" id="services-grid-section">
    <ServicesGrid services={servicesForGrid} />
  </section>

  <div id="service-detail-outlet">
    {servicesData.map(service => (
      <ServiceDetail service={service} />
    ))}
  </div>

</BaseLayout>

<script is:inline>
  function initializeIndexInteraction() {
    // MENSAJE DE PRUEBA 1
    console.log("✅ Script de interacción INICIADO"); 

    const servicesGridSection = document.getElementById('services-grid-section');
    if (!servicesGridSection) return;

    const serviceCards = servicesGridSection.querySelectorAll('.service-card'); 
    
    // MENSAJE DE PRUEBA 2
    console.log(`🔎 Encontradas ${serviceCards.length} tarjetas de servicio.`);

    const detailOutlet = document.getElementById('service-detail-outlet');
    let currentlyOpenDetail = null;

    serviceCards.forEach(card => {
      if (card.dataset.listenerAttached) return;

      card.addEventListener('click', (e) => {
        e.preventDefault();
        
        const serviceId = card.getAttribute('data-service-id');
        console.log(`🖱️ Clic en tarjeta: ${serviceId}`); // MENSAJE DE PRUEBA 3
        if (!serviceId) return;

        if (currentlyOpenDetail) {
          currentlyOpenDetail.style.display = 'none';
          currentlyOpenDetail.classList.remove('is-visible');
        }

        const newDetailToShow = detailOutlet.querySelector(`#service-${serviceId}`);
        if (newDetailToShow) {
          newDetailToShow.style.display = 'block';
          setTimeout(() => {
            newDetailToShow.classList.add('is-visible');
          }, 10);
          
          currentlyOpenDetail = newDetailToShow;

          servicesGridSection.classList.add('is-active');
          newDetailToShow.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
      card.dataset.listenerAttached = 'true';
    });
  }
  
  document.addEventListener('DOMContentLoaded', initializeIndexInteraction);
  document.addEventListener('astro:page-load', initializeIndexInteraction);
</script>

<style>
  .services-section-wrapper {
    padding-top: 6rem;
    padding-bottom: 6rem;
    transition: transform 0.5s ease-out, opacity 0.5s ease-out;
  }
  .services-section-wrapper.is-active {
    transform: translateY(-20px) scale(0.98);
    opacity: 0.8;
  }
  #service-detail-outlet {
    position: relative;
    z-index: 10;
  }
  .service-detail-container.is-visible {
    opacity: 1;
  }
</style>```

**Después de actualizar el archivo:**

1.  Guarda el archivo.
2.  Ve a tu navegador, abre la **Consola de Desarrollador** (como en el paso 7).
3.  Refresca la página (`Cmd + R`).
4.  Por favor, envíame una nueva **captura de pantalla** de la consola.

Esta vez, deberíamos ver nuestros mensajes de prueba. Esto nos dirá exactamente en qué punto se está deteniendo el proceso.