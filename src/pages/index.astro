<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StackSolver — Tecnología que se adapta a su empresa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#fff;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#6366f1;--indigo-sub:#eef2ff;
  --green:#16a34a;--green-sub:#f0fdf4;
  --text:#18181b;--text2:#71717a;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,sans-serif;
}
body.dark{
  --bg:#030303;--surface:#0f0f0f;--border:#1f1f1f;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#0a0a0a;--accent-sub:#141414;
  --indigo:#818cf8;--indigo-sub:#1a1a2e;
  --green:#4ade80;--green-sub:#042a12;
  --text:#fafafa;--text2:#737373;--text3:#404040;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:background .2s}
body.dark nav{background:rgba(3,3,3,.85)}
.logo{font-size:14px;font-weight:800;letter-spacing:-.4px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-links{display:flex;gap:2px}
.nl{font-size:13px;color:var(--text2);padding:5px 11px;border-radius:var(--r);transition:all .15s;font-weight:500}
.nl:hover{color:var(--text);background:var(--accent-sub)}
.nl.on{color:var(--text)}
.nav-r{display:flex;gap:6px;align-items:center}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);transition:all .15s}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.btn-nav{display:flex;align-items:center;gap:5px;padding:6px 14px;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text);font-family:var(--font);transition:all .15s}
.btn-nav:hover{background:var(--accent-sub)}

/* ═══ HERO ═══ */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:100px 28px 80px;position:relative;overflow:hidden}
/* Subtle grid background */
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:60px 60px;opacity:.35;pointer-events:none}
/* Soft radial glow */
.hero::after{content:'';position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:800px;height:800px;background:radial-gradient(ellipse,rgba(99,102,241,.06) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 420px;gap:64px;align-items:center;position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px 4px 4px;border:1px solid var(--border);border-radius:20px;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:24px}
.hero-badge-dot{width:20px;height:20px;border-radius:50%;background:var(--indigo-sub);display:flex;align-items:center;justify-content:center}
.hero-badge-dot svg{width:10px;height:10px;color:var(--indigo)}
.hero-h1{font-size:clamp(38px,5vw,62px);font-weight:900;letter-spacing:-1.5px;line-height:1.08;margin-bottom:20px}
.hero-h1 .accent{color:var(--indigo)}
/* Animated word */
.word-cycle{display:inline-block;position:relative;overflow:hidden;vertical-align:bottom}
.word-cycle span{display:block;animation:wordcycle 8s infinite}
@keyframes wordcycle{
  0%,18%{transform:translateY(0);opacity:1}
  22%,48%{transform:translateY(-100%);opacity:0}
  50%,68%{transform:translateY(-100%);opacity:1}
  72%,98%{transform:translateY(-200%);opacity:0}
  100%{transform:translateY(0);opacity:1}
}
.word-cycle span:nth-child(2){animation-delay:.5s;position:absolute;top:100%;left:0}
.word-cycle span:nth-child(3){animation-delay:4s;position:absolute;top:200%;left:0}
.hero-sub{font-size:17px;color:var(--text2);line-height:1.65;max-width:480px;margin-bottom:32px}
.hero-sub strong{color:var(--text);font-weight:600}
.hero-ctas{display:flex;gap:10px;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:var(--r);font-size:14px;font-weight:600;cursor:pointer;border:1px solid var(--accent);background:var(--accent);color:var(--accent-fg);font-family:var(--font);transition:all .15s}
.btn-primary:hover{opacity:.88}
.btn-secondary{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:var(--r);font-size:14px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text2);font-family:var(--font);transition:all .15s}
.btn-secondary:hover{border-color:var(--text3);color:var(--text)}
.hero-proof{display:flex;align-items:center;gap:12px;margin-top:32px;padding-top:24px;border-top:1px solid var(--border)}
.proof-item{font-size:12px;color:var(--text3);display:flex;align-items:center;gap:4px}
.proof-sep{width:1px;height:12px;background:var(--border)}

/* PRODUCT PREVIEW (hero right) */
.preview-wrap{position:relative}
/* Hero quote (above preview card) */
.hero-quote{margin-bottom:18px;padding:12px 16px;border-left:2px solid var(--indigo);background:var(--indigo-sub);border-radius:0 var(--r) var(--r) 0}
.hero-quote p{font-size:12.5px;line-height:1.5;color:var(--text);font-style:italic;font-weight:500;letter-spacing:-.15px;margin:0}
.hero-quote p strong{color:var(--indigo);font-weight:700;font-style:normal}
.preview-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:0 0 0 1px var(--border),0 20px 60px rgba(0,0,0,.04)}
.preview-bar{display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid var(--border);background:var(--accent-sub)}
.pbar-dots{display:flex;gap:5px}
.pd{width:10px;height:10px;border-radius:50%;background:var(--border)}
.pd:nth-child(1){background:#ff5f57}.pd:nth-child(2){background:#ffbd2e}.pd:nth-child(3){background:#28ca41}
.pbar-title{font-size:11px;color:var(--text3);font-weight:500;margin-left:4px}
.preview-content{padding:16px}
.preview-row{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:6px}
.pm{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;transition:all .2s}
.pm:hover{border-color:var(--text3)}
.pm-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.pm-ico{width:22px;height:22px;border-radius:5px;background:var(--accent-sub);display:flex;align-items:center;justify-content:center}
.pm-ico svg{width:11px;height:11px;color:var(--text2)}
.pm-dot{width:7px;height:7px;border-radius:50%;background:#28ca41}
.pm-dot.amber{background:#ffbd2e}
.pm-lbl{font-size:10px;font-weight:600;color:var(--text);margin-bottom:1px}
.pm-val{font-size:9px;color:var(--text3)}
.preview-stat{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-top:6px;padding-top:10px;border-top:1px solid var(--border)}
.pst{text-align:center}
.pst-n{font-size:13px;font-weight:800;color:var(--text);counter-reset:num var(--end)}
.pst-l{font-size:9px;color:var(--text3);margin-top:1px}
/* Floating badge on preview */
.preview-badge{position:absolute;bottom:-14px;right:-14px;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(0,0,0,.06)}
.pb-ico{width:28px;height:28px;border-radius:7px;background:var(--green-sub);display:flex;align-items:center;justify-content:center}
.pb-ico svg{width:14px;height:14px;color:var(--green)}
.pb-text strong{display:block;font-size:12px;font-weight:700;color:var(--text)}
.pb-text span{font-size:10px;color:var(--text3)}

/* ═══ MARQUEE ═══ */
.marquee-wrap{border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden;padding:12px 0;background:var(--bg)}
.marquee-track{display:flex;gap:0;white-space:nowrap;animation:marquee 28s linear infinite}
.marquee-track:hover{animation-play-state:paused}
.marquee-item{display:inline-flex;align-items:center;gap:8px;padding:0 24px;font-size:12px;font-weight:500;color:var(--text3)}
.marquee-item svg{width:13px;height:13px;color:var(--text3);opacity:.6}
.marquee-sep{color:var(--border);font-size:18px}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ═══ SERVICES ═══ */
.section{max-width:1100px;margin:0 auto;padding:96px 28px}
.sec-eyebrow{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:12px}
.sec-h{font-size:clamp(28px,3.5vw,42px);font-weight:800;letter-spacing:-.8px;line-height:1.15;margin-bottom:12px}
.sec-sub{font-size:15px;color:var(--text2);line-height:1.65;max-width:520px;margin-bottom:48px}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.svc{background:var(--surface);padding:28px 24px;transition:all .2s;cursor:default}
.svc:hover{background:var(--accent-sub)}
.svc-ico{width:40px;height:40px;border-radius:10px;background:var(--accent-sub);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;margin-bottom:16px;transition:all .2s}
.svc:hover .svc-ico{background:var(--indigo-sub);border-color:#c7d2fe}
.svc:hover .svc-ico svg{color:var(--indigo)}
.svc-ico svg{width:20px;height:20px;color:var(--text2);transition:color .2s}
.svc h3{font-size:15px;font-weight:700;margin-bottom:6px;letter-spacing:-.2px}
.svc p{font-size:13px;color:var(--text2);line-height:1.55}
.svc-tag{display:inline-flex;margin-top:12px;font-size:10px;font-weight:600;letter-spacing:.4px;text-transform:uppercase;color:var(--text3)}

/* ═══ WORLD MAP ═══ */
.map-section{background:var(--accent-sub);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.map-inner{max-width:1100px;margin:0 auto;padding:80px 28px;display:grid;grid-template-columns:320px 1fr;gap:64px;align-items:center}
.map-text{}
.region-pills{display:flex;flex-direction:column;gap:8px;margin-top:24px}
.region-pill{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--r);background:var(--surface);border:1px solid var(--border)}
.rp-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.rp-dot.active{background:var(--indigo);box-shadow:0 0 0 3px rgba(99,102,241,.15)}
.region-pill strong{font-size:13px;font-weight:600}
.region-pill span{font-size:11px;color:var(--text3);margin-left:auto}
.map-canvas-wrap{position:relative}
canvas#worldMap{width:100%;height:auto;display:block}
.map-note{font-size:12px;color:var(--text3);margin-top:12px;text-align:center}

/* ═══ HOW ═══ */
.how-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;margin-top:40px}
.how-grid::before{content:'';position:absolute;top:19px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,var(--border) 20%,var(--border) 80%,transparent);pointer-events:none}
.how-step{display:flex;flex-direction:column;align-items:center;gap:10px;padding:0 8px;position:relative;z-index:1}
.hs-num{width:38px;height:38px;border-radius:50%;background:var(--surface);border:1px solid var(--border);font-size:13px;font-weight:700;color:var(--text2);display:flex;align-items:center;justify-content:center;transition:all .2s}
.how-step:hover .hs-num{border-color:var(--indigo);color:var(--indigo);background:var(--indigo-sub)}
.hs-lbl{font-size:12px;font-weight:600;text-align:center;color:var(--text)}
.hs-sub{font-size:11px;color:var(--text3);text-align:center;line-height:1.45}
.how-remote{margin-top:32px;display:flex;align-items:center;gap:8px;padding:12px 16px;border-radius:var(--r);background:var(--surface);border:1px solid var(--border);max-width:480px}
.how-remote svg{width:14px;height:14px;color:var(--text3);flex-shrink:0}
.how-remote span{font-size:13px;color:var(--text2)}
.how-remote strong{color:var(--text)}

/* ═══ CTA ═══ */
.cta-section{border-top:1px solid var(--border)}
.cta-inner{max-width:1100px;margin:0 auto;padding:96px 28px;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center}
.cta-h{font-size:clamp(24px,3vw,38px);font-weight:800;letter-spacing:-.6px;line-height:1.2}
.cta-sub{font-size:14px;color:var(--text2);margin-top:8px;line-height:1.6}
.cta-actions{display:flex;flex-direction:column;gap:10px;flex-shrink:0}
.diag-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;text-align:center;min-width:220px}
.diag-card .badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--indigo);background:var(--indigo-sub);padding:2px 8px;border-radius:4px;margin-bottom:12px}
.diag-card .dc-h{font-size:14px;font-weight:700;margin-bottom:4px}
.diag-card .dc-s{font-size:12px;color:var(--text3);margin-bottom:14px}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:24px 28px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;max-width:100%}
.footer-left{display:flex;align-items:center;gap:20px}
.footer-link{font-size:12px;color:var(--text3);transition:color .15s}
.footer-link:hover{color:var(--text2)}
.fc{display:flex;align-items:center;gap:5px;font-size:13px;color:var(--text2)}
.fc a{color:var(--text2);transition:color .15s}
.fc a:hover{color:var(--text)}
.fc svg{width:13px;height:13px;color:var(--text3)}

/* MOBILE */
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;gap:40px}
  .preview-wrap{display:none}
  .services-grid{grid-template-columns:1fr 1fr}
  .map-inner{grid-template-columns:1fr}
  .cta-inner{grid-template-columns:1fr}
  .how-grid{grid-template-columns:1fr 1fr;gap:20px}
  .how-grid::before{display:none}
  .section{padding:64px 20px}
}
@media(max-width:560px){
  .services-grid{grid-template-columns:1fr}
  nav{padding:0 16px}
  .hero{padding:88px 20px 60px}
}
/* HAMBURGER NAV */
.hamburger{display:none;width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;align-items:center;justify-content:center;color:var(--text2);transition:all .15s;flex-shrink:0}
.mob-menu{display:none;position:fixed;top:52px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:12px 16px 16px;flex-direction:column;gap:2px;z-index:199;box-shadow:0 8px 24px rgba(0,0,0,.08)}
body.dark .mob-menu{box-shadow:0 8px 24px rgba(0,0,0,.35)}
.mob-menu.open{display:flex}
.mob-link{font-size:15px;font-weight:500;color:var(--text2);padding:10px 12px;border-radius:var(--r);transition:all .15s;text-decoration:none;display:block}
.mob-link:hover,.mob-link.on{color:var(--text);background:var(--accent-sub)}
.mob-divider{height:1px;background:var(--border);margin:6px 0}
.mob-cta{display:flex;align-items:center;justify-content:center;gap:6px;padding:10px 14px;border-radius:var(--r);font-size:14px;font-weight:600;border:1px solid var(--border);background:var(--surface);color:var(--text);margin-top:4px;text-decoration:none;transition:all .15s}
.mob-cta:hover{background:var(--accent-sub)}
.mob-lang-row{display:flex;align-items:center;justify-content:space-between;padding:6px 12px 2px}
.mob-lang-lbl{font-size:12px;color:var(--text3)}
@media(max-width:768px){
  .nav-links,.btn-nav{display:none!important}
  .hamburger{display:flex}
  .lang-wrap{display:none}
}

/* Scroll fade-in */
.fade-in{opacity:0;transform:translateY(16px);transition:opacity .6s ease,transform .6s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}
</style>

