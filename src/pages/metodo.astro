<style>
:root{
  --bg:#fff;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#6366f1;--indigo-sub:#eef2ff;--indigo-strong:#4f46e5;
  --green:#16a34a;--green-sub:#f0fdf4;
  --amber:#d97706;--amber-sub:#fffbeb;
  --text:#18181b;--text2:#52525b;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,sans-serif;
}
body.dark{
  --bg:#030303;--surface:#0f0f0f;--border:#1f1f1f;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#0a0a0a;--accent-sub:#141414;
  --indigo:#818cf8;--indigo-sub:#1a1a2e;--indigo-strong:#a5b4fc;
  --green:#4ade80;--green-sub:#042a12;
  --amber:#f59e0b;--amber-sub:#1c1410;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:background .2s}
body.dark nav{background:rgba(3,3,3,.85)}
.logo{font-size:14px;font-weight:800;letter-spacing:-.4px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-links{display:flex;gap:2px}
.nl{font-size:13px;color:var(--text2);padding:5px 11px;border-radius:var(--r);transition:all .15s;font-weight:500}
.nl:hover{color:var(--text);background:var(--accent-sub)}
.nl.on{color:var(--text)}
.nav-r{display:flex;gap:6px;align-items:center}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);transition:all .15s}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.btn-nav{display:flex;align-items:center;gap:5px;padding:6px 14px;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text);font-family:var(--font);transition:all .15s}
.btn-nav:hover{background:var(--accent-sub)}

/* HERO */
.hero{padding:120px 28px 60px;position:relative;overflow:hidden;border-bottom:1px solid var(--border)}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:60px 60px;opacity:.35;pointer-events:none}
.hero::after{content:'';position:absolute;top:-30%;left:50%;transform:translateX(-50%);width:900px;height:900px;background:radial-gradient(ellipse,rgba(99,102,241,.08) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:880px;margin:0 auto;width:100%;position:relative;z-index:1;text-align:center}
.hero-eyebrow{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border:1px solid var(--border);border-radius:20px;font-size:11px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--indigo);background:var(--indigo-sub);margin-bottom:24px}
.hero-eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--indigo);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero-h1{font-size:clamp(36px,5vw,58px);font-weight:900;letter-spacing:-1.5px;line-height:1.05;margin-bottom:16px;color:var(--text)}
.hero-sub{font-size:clamp(18px,2vw,22px);font-weight:500;color:var(--text2);line-height:1.4;max-width:620px;margin:0 auto 12px}
.hero-sub .accent{color:var(--indigo);font-weight:700}
.hero-meta{font-size:13px;color:var(--text3);margin-top:24px;display:flex;justify-content:center;gap:14px;flex-wrap:wrap}
.hero-meta span{display:inline-flex;align-items:center;gap:4px}
.hero-meta .dot{width:3px;height:3px;border-radius:50%;background:var(--text3)}

/* ARTICLE */
article{max-width:720px;margin:0 auto;padding:72px 28px 96px}
article h2{font-size:clamp(26px,3vw,34px);font-weight:800;letter-spacing:-.7px;line-height:1.2;margin:64px 0 20px;color:var(--text);scroll-margin-top:80px}
article h2:first-child{margin-top:0}
article h3{font-size:clamp(19px,2vw,22px);font-weight:700;letter-spacing:-.3px;line-height:1.3;margin:40px 0 12px;color:var(--text)}
article h3::before{content:'';display:inline-block;width:18px;height:2px;background:var(--indigo);margin-right:10px;vertical-align:middle;margin-bottom:4px}
article p{font-size:17px;line-height:1.75;color:var(--text);margin-bottom:18px;font-weight:400}
article p strong{color:var(--text);font-weight:700}
article em{color:var(--text2);font-style:italic}
article ul,article ol{margin:0 0 24px 0;padding-left:0;list-style:none}
article ul li,article ol li{position:relative;padding-left:22px;margin-bottom:10px;font-size:16.5px;line-height:1.7;color:var(--text)}
article ul li::before{content:'';position:absolute;left:0;top:11px;width:8px;height:8px;border-radius:50%;background:var(--indigo)}
article ol{counter-reset:oli}
article ol li{counter-increment:oli;padding-left:32px}
article ol li::before{content:counter(oli) ".";position:absolute;left:0;top:0;font-weight:700;color:var(--indigo);font-size:16.5px}
article blockquote{border-left:3px solid var(--indigo);padding:14px 20px;margin:24px 0;background:var(--indigo-sub);border-radius:0 var(--r) var(--r) 0;font-size:16.5px;line-height:1.7;color:var(--text);font-style:italic}
article blockquote p{font-size:16.5px;margin-bottom:0;font-style:italic;font-weight:500}
article pre{background:var(--accent-sub);border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;overflow-x:auto;margin:20px 0;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13.5px;line-height:1.6;color:var(--text)}
article a{color:var(--indigo);border-bottom:1px solid transparent;transition:border-color .15s}
article a:hover{border-bottom-color:var(--indigo)}
article hr{border:none;border-top:1px solid var(--border);margin:56px 0}
.callout{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--indigo);border-radius:var(--r);padding:22px 24px;margin:28px 0}
.callout strong{display:block;font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--indigo);margin-bottom:8px}
.callout p{font-size:16px;margin-bottom:0}

/* Article h4 */
article h4{font-size:17px;font-weight:700;letter-spacing:-.2px;line-height:1.35;margin:28px 0 12px;color:var(--text)}

/* Memory layers table */
.memory-layers{margin:20px 0 28px;overflow-x:auto}
.mem-table{width:100%;border-collapse:collapse;font-size:14.5px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.mem-table th{text-align:left;padding:12px 16px;font-size:12px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;color:var(--text3);background:var(--accent-sub);border-bottom:1px solid var(--border)}
.mem-table td{padding:14px 16px;vertical-align:top;border-bottom:1px solid var(--border);line-height:1.55;color:var(--text)}
.mem-table tr:last-child td{border-bottom:none}
.mem-table td:first-child{white-space:nowrap;width:180px}
.mem-table code{background:var(--accent-sub);padding:2px 7px;border-radius:4px;font-size:13px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:var(--indigo-strong);font-weight:600}
article code{background:var(--accent-sub);padding:1px 6px;border-radius:4px;font-size:14.5px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:var(--indigo-strong);font-weight:500}

/* Figure with image */
figure.fig{margin:28px 0;text-align:center}
figure.fig img{max-width:100%;height:auto;border:1px solid var(--border);border-radius:10px;display:block;margin:0 auto;background:var(--accent-sub)}
figure.fig figcaption{margin-top:12px;font-size:13px;color:var(--text2);line-height:1.55;max-width:560px;margin-left:auto;margin-right:auto;font-style:italic}
figure.fig figcaption strong{color:var(--text);font-weight:600;font-style:normal}
/* Email figure — narrower for natural mail proportions */
figure.fig-email img{max-width:480px;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.06)}
body.dark figure.fig-email img{box-shadow:0 4px 24px rgba(0,0,0,.3)}

/* TIER CARDS (3 paths) */
.tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:32px 0}
.tier{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;transition:all .2s}
.tier:hover{border-color:var(--text3);transform:translateY(-2px)}
.tier.featured{border-color:var(--indigo);background:var(--indigo-sub)}
.tier-num{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:8px}
.tier.featured .tier-num{color:var(--indigo)}
.tier-name{font-size:18px;font-weight:800;letter-spacing:-.3px;margin-bottom:6px;color:var(--text)}
.tier-price{font-size:12px;color:var(--text3);margin-bottom:14px;font-weight:500}
.tier-desc{font-size:14px;color:var(--text2);line-height:1.6;margin-bottom:14px}
.tier-ideal{font-size:13px;color:var(--text);font-weight:500;line-height:1.55;padding-top:12px;border-top:1px solid var(--border)}
.tier.featured .tier-ideal{border-top-color:rgba(99,102,241,.3)}

/* CTA FINAL */
.cta-final{background:var(--accent);color:var(--accent-fg);border-radius:14px;padding:40px 36px;margin:48px 0 24px;text-align:center}
.cta-final h3{color:var(--accent-fg);font-size:24px;margin-bottom:8px;margin-top:0}
.cta-final h3::before{display:none}
.cta-final p{color:var(--accent-fg);opacity:.85;margin-bottom:20px;font-size:15px}
.cta-final .btn-cta{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:var(--accent-fg);color:var(--accent);border-radius:var(--r);font-weight:700;font-size:15px;transition:transform .15s}
.cta-final .btn-cta:hover{transform:translateY(-1px)}

/* AUTHOR BOX */
.author{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px;margin-top:56px}
.author-head{display:flex;align-items:center;gap:16px;margin-bottom:16px}
.author-avatar{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--indigo) 0%,var(--indigo-strong) 100%);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:20px;letter-spacing:-.5px;flex-shrink:0}
.author-name{font-size:17px;font-weight:700;letter-spacing:-.2px;color:var(--text)}
.author-role{font-size:13px;color:var(--text2);margin-top:2px}
.author p{font-size:14.5px;line-height:1.7;color:var(--text2);margin-bottom:14px}
.author-links{display:flex;gap:14px;flex-wrap:wrap;font-size:13px}
.author-links a{color:var(--indigo);font-weight:500}

