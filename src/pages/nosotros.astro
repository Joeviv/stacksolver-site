<style>
:root{
  --bg:#fafafa;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#6366f1;--indigo-sub:#eef2ff;
  --green:#16a34a;--green-sub:#f0fdf4;
  --amber:#d97706;--amber-sub:#fffbeb;
  --text:#18181b;--text2:#71717a;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,sans-serif;
}
body.dark{
  --bg:#0a0a0a;--surface:#111;--border:#27272a;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#18181b;--accent-sub:#27272a;
  --indigo:#818cf8;--indigo-sub:#1e1b4b;
  --green:#4ade80;--green-sub:#052e16;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased}
a{text-decoration:none}
nav{position:fixed;top:0;left:0;right:0;z-index:100;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:var(--bg);border-bottom:1px solid var(--border)}
.logo{font-size:14px;font-weight:700;letter-spacing:-.3px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-links{display:flex;gap:4px;align-items:center}
.nl{font-size:13px;color:var(--text2);padding:5px 10px;border-radius:var(--r);transition:all .15s;font-family:var(--font)}
.nl:hover{color:var(--text);background:var(--accent-sub)}
.nl.on{color:var(--text);font-weight:500}
.nav-r{display:flex;gap:6px}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2)}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.wrap{max-width:760px;margin:0 auto;padding:80px 24px 64px}
.eyebrow{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--indigo);margin-bottom:10px}
h1.t{font-size:34px;font-weight:800;letter-spacing:-.7px;line-height:1.15;margin-bottom:12px}
h2.t{font-size:22px;font-weight:700;letter-spacing:-.4px;margin-bottom:8px}
.sub{font-size:15px;color:var(--text2);line-height:1.7;margin-bottom:0}
.div{height:1px;background:var(--border);margin:48px 0}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin:32px 0}
.stat{background:var(--surface);padding:20px 16px;text-align:center}
.stat-n{font-size:28px;font-weight:800;letter-spacing:-.5px;color:var(--text)}
.stat-l{font-size:11px;color:var(--text3);font-weight:500;margin-top:2px}
.pill-row{display:flex;flex-wrap:wrap;gap:6px;margin:20px 0 32px}
.pill{font-size:12px;font-weight:500;padding:4px 12px;border-radius:20px;border:1px solid var(--border);color:var(--text2)}
/* HOW WE WORK */
.steps-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin:24px 0 32px;position:relative}
.steps-grid::before{content:'';position:absolute;top:18px;left:10%;right:10%;height:1px;background:var(--border)}
.sg-step{display:flex;flex-direction:column;align-items:center;gap:8px;position:relative;z-index:1}
.sg-n{width:36px;height:36px;border-radius:50%;background:var(--surface);border:1px solid var(--border);font-size:12px;font-weight:700;color:var(--text2);display:flex;align-items:center;justify-content:center}
.sg-l{font-size:11px;color:var(--text2);text-align:center;line-height:1.4}
/* FAQ */
.faq-list{border:1px solid var(--border);border-radius:10px;overflow:hidden;margin:20px 0 0}
.faq-item{border-bottom:1px solid var(--border)}
.faq-item:last-child{border-bottom:none}
.faq-q{width:100%;display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:none;border:none;font-family:var(--font);font-size:14px;font-weight:500;color:var(--text);cursor:pointer;text-align:left}
.faq-q:hover{background:var(--accent-sub)}
.faq-q svg{flex-shrink:0;transition:transform .2s;color:var(--text3)}
.faq-item.open .faq-q svg{transform:rotate(180deg)}
.faq-a{display:none;padding:0 20px 16px;font-size:13px;color:var(--text2);line-height:1.7}
.faq-item.open .faq-a{display:block}
/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px}
.cf{grid-column:1/-1}
.field label{display:block;font-size:11px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.field input,.field select,.field textarea{width:100%;padding:10px 13px;border:1px solid var(--border);border-radius:var(--r);background:var(--bg);color:var(--text);font-size:13px;font-family:var(--font);outline:none;transition:border .15s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--text3)}
.field input::placeholder,.field textarea::placeholder{color:var(--text3)}
.field textarea{resize:vertical;min-height:100px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:var(--r);font-size:14px;font-weight:600;cursor:pointer;border:1px solid transparent;font-family:var(--font);transition:all .15s}
.btn-dark{background:var(--accent);color:var(--accent-fg)}
.btn-dark:hover{opacity:.85}
.contact-aside{display:flex;flex-direction:column;gap:14px}
.c-card{padding:16px 20px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface)}
.c-card .cc-label{font-size:11px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--text3);margin-bottom:6px}
.c-card .cc-val{font-size:14px;font-weight:500;color:var(--text);display:flex;align-items:center;gap:6px}
.c-card .cc-val svg{width:15px;height:15px;color:var(--text2)}
.c-card .cc-sub{font-size:12px;color:var(--text2);margin-top:4px;line-height:1.5}
.partner-strip{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--r);background:var(--green-sub);border:1px solid #bbf7d0;font-size:12px;font-weight:500;color:var(--green)}
body.dark .partner-strip{border-color:var(--green-sub)}
/* FOOTER */
footer{border-top:1px solid var(--border);padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;max-width:760px;margin:0 auto}
.fc{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text2)}
.fc a{color:var(--text2);text-decoration:none}
.fc a:hover{color:var(--text)}
.fc svg{width:14px;height:14px;color:var(--text3)}
@media(max-width:600px){
  .stat-row{grid-template-columns:1fr 1fr}
  .contact-grid{grid-template-columns:1fr}
  .steps-grid{grid-template-columns:1fr;gap:16px}
  .steps-grid::before{display:none}
  h1.t{font-size:26px}
}
/* HAMBURGER NAV */
.hamburger{display:none;width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;align-items:center;justify-content:center;color:var(--text2);transition:all .15s;flex-shrink:0}
.mob-menu{display:none;position:fixed;top:52px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:12px 16px 16px;flex-direction:column;gap:2px;z-index:199;box-shadow:0 8px 24px rgba(0,0,0,.08)}
body.dark .mob-menu{box-shadow:0 8px 24px rgba(0,0,0,.35)}
.mob-menu.open{display:flex}
.mob-link{font-size:15px;font-weight:500;color:var(--text2);padding:10px 12px;border-radius:var(--r);transition:all .15s;text-decoration:none;display:block}
.mob-link:hover,.mob-link.on{color:var(--text);background:var(--accent-sub)}
.mob-lang-row{display:flex;align-items:center;justify-content:space-between;padding:6px 12px 2px}
.mob-lang-lbl{font-size:12px;color:var(--text3)}
@media(max-width:768px){
  .nav-links{display:none!important}
  .hamburger{display:flex}
  .lang-wrap{display:none}
}
</style>

