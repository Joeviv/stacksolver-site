---
import ProductPageLayout from '../../layouts/ProductPageLayout.astro';

const pageTitle = "Diseño Web de Alto Rendimiento con Astro | Stacksolver.tech";
const serviceName = "Tu Web, Reimaginada para la Era Digital";
const leadParagraph = "En un mundo saturado de sitios lentos y anticuados, te damos la ventaja competitiva. Creamos experiencias web ultrarrápidas, seguras y visualmente impactantes que no solo atraen visitantes, sino que los convierten en clientes. Tu sitio web debe ser tu mejor vendedor, no un simple folleto digital.";

const webFeatures = [
  {
    id: "web-astro",
    name: "Fundamentos del Futuro: Creado con Astro",
    description: "Utilizamos Astro, un framework de última generación, para construir sitios que son increíblemente rápidos por diseño.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 2.18a14.98 14.98 0 00-2.58 5.84m2.58 0A6 6 0 0114.37 15.59m0 0v4.8m0-4.8a6 6 0 01-7.38-5.84m7.38 0a14.98 14.98 0 00-12.12-6.16A14.98 14.98 0 002.18 9.63a14.98 14.98 0 005.84 2.58m0 0A6 6 0 012.18 15.59m0 0a14.98 14.98 0 006.16 12.12A14.98 14.98 0 0015.59 21.82a14.98 14.98 0 002.58-5.84m-2.58 0a6 6 0 015.84-7.38" /></svg>`,
    media: { type: 'localVideo', src: '/videos/features/web-astro.mp4' },
    descriptiveText: "La velocidad de tu web impacta directamente en tu ranking en Google y en la paciencia de tus usuarios. Astro revoluciona esto al enviar solo HTML y CSS al navegador por defecto, cargando JavaScript únicamente cuando es estrictamente necesario. El resultado es un sitio que se siente instantáneo, una experiencia de usuario fluida y una base técnica sólida que Google adora. Dejamos atrás los pesados sistemas del pasado para ofrecerte el rendimiento del mañana."
  },
  {
    id: "web-seo-ai",
    name: "Visibilidad Estratégica: SEO para Humanos y para IA",
    description: "Construimos con una estructura impecable, optimizada para los motores de búsqueda de hoy y las consultas de IA del futuro.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/web-seo.jpg' },
    descriptiveText: "El SEO ya no es solo sobre palabras clave. Es sobre rendimiento, accesibilidad y datos estructurados. Nuestras webs están meticulosamente construidas para ser fácilmente rastreables por Google, mejorando tu posicionamiento. Además, las preparamos para la era de la IA, asegurando que el contenido sea claro y contextual, listo para ser interpretado y recomendado por los nuevos sistemas de búsqueda inteligente. Te posicionamos para ganar hoy y dominar mañana."
  },
  {
    id: "web-design",
    name: "Diseño que Convierte: Estética y Usabilidad de la Mano",
    description: "Creamos interfaces modernas, intuitivas y centradas en el usuario que guían a la acción y reflejan la calidad de tu marca.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.998 15.998 0 011.622-3.385m5.043.025a15.998 15.998 0 001.622-3.385m3.388 1.62a15.998 15.998 0 00-1.622-3.385m-5.043.025a15.998 15.998 0 01-3.388-1.621m7.722 7.722a15.998 15.998 0 00-3.388-1.622m-5.043-.025a15.998 15.998 0 01-1.622-3.385m-3.388 1.621a15.998 15.998 0 011.622-3.385m3.388 1.622a15.998 15.998 0 013.388-1.622m5.043.025a15.998 15.998 0 003.388-1.622m-7.722 7.722a15.998 15.998 0 01-3.388-1.621" /></svg>`,
    media: { type: 'localImage', src: '/images/features/web-ux.jpg' },
    descriptiveText: "Un diseño hermoso que no es fácil de usar, es un diseño fallido. Nuestro proceso se centra en la experiencia del usuario (UX). Mapeamos los recorridos de tus clientes ideales para crear una navegación lógica, llamadas a la acción claras y una jerarquía visual que comunica tu mensaje de forma efectiva. El resultado es un sitio que no solo se ve increíble, sino que también funciona como una herramienta de negocio eficiente, convirtiendo la curiosidad en acción."
  },
  {
    id: "web-integrations",
    name: "Más Allá de lo Estático: Integraciones y Contenido Dinámico",
    description: "Tu web no tiene por qué ser una isla. La conectamos con las herramientas que ya usas para automatizar y potenciar tu negocio.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.25a.75.75 0 01-.75-.75v-7.5c0-.414.336-.75.75-.75h3.75m9 8.25v-7.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21m-4.5 0H9M15 21v-7.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21m0 0h1.5m1.5 0H18m-3-7.5V3m0 10.5V3m0 10.5H9.75m4.5 0H12m2.25 0V3m0 10.5a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75M3.75 12H3m0 0V3m0 9.75H5.25m-1.5 0V3m0 9.75a.75.75 0 00.75.75h1.5a.75.75 0 00.75-.75M21 12h-1.5m0 0V3m0 9.75h-1.5m1.5 0V3m0 9.75a.75.75 0 01-.75.75h-1.5a.75.75 0 01-.75-.75" /></svg>`,
    media: { type: 'localVideo', src: '/videos/features/web-integrations.mp4' },
    descriptiveText: "¿Necesitas un blog que puedas actualizar fácilmente? Lo conectamos a un CMS moderno. ¿Quieres que los formularios de contacto lleguen a tu CRM? Hecho. ¿Vendes productos y necesitas sincronizar tu inventario? Podemos integrarlo. Construimos tu web como una plataforma central, conectada a servicios de terceros (APIs), bases de datos o aplicaciones internas para crear un ecosistema digital cohesivo y automatizado que te ahorra tiempo y dinero."
  },
  {
    id: "web-security",
    name: "Fortaleza Digital: Seguridad y Mantenimiento Proactivo",
    description: "La arquitectura moderna de Astro reduce drásticamente las vulnerabilidades, y nosotros nos encargamos del resto.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.6-3.752A11.953 11.953 0 0012 2.75z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/web-security.jpg' },
    descriptiveText: "Los sitios web tradicionales basados en WordPress y plugins son el objetivo número uno de los hackers. La arquitectura de Astro, al generar principalmente archivos estáticos, elimina gran parte de la superficie de ataque. No hay una base de datos expuesta en el front-end ni un panel de admin vulnerable. Nosotros complementamos esta ventaja con prácticas de desarrollo seguras, monitoreo constante y planes de mantenimiento para que puedas dormir tranquilo sabiendo que tu inversión digital está protegida."
  }
];

const featureSections = [
    {
        title: "Nuestra Filosofía de Desarrollo Web",
        features: webFeatures
    }
];
---

<ProductPageLayout
  pageTitle={pageTitle}
  serviceName={serviceName}
  leadParagraph={leadParagraph}
  featureSections={featureSections}
/>