---
import ProductPageLayout from '../../layouts/ProductPageLayout.astro';

const pageTitle = "Plataformas de Aprendizaje Moodle Potenciadas por AWS | Stacksolver.tech";
const serviceName = "Tu Academia Digital, Sin Límites";
const leadParagraph = "Transformamos Moodle, la plataforma LMS líder del mundo, en el motor de conocimiento para tu organización. Ya sea para capacitar a tu equipo, educar a tus estudiantes o realizar el onboarding de nuevos talentos, creamos un ecosistema de aprendizaje a tu medida, robusto y totalmente bajo tu control.";

const lmsFeatures = [
  {
    id: "lms-moodle",
    name: "Moodle: El Motor de Aprendizaje de Código Abierto",
    description: "Te damos el control de una plataforma flexible y reconocida mundialmente, sin las ataduras de licencias costosas.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path d="M12 18.375a9.375 9.375 0 01-9.375-9.375h18.75A9.375 9.375 0 0112 18.375z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75v14.625m-9.375-9.375h18.75"></path></svg>`,
    media: { type: 'localImage', src: '/images/features/lms-dashboard.jpg' },
    descriptiveText: "Moodle es la elección de miles de universidades y corporaciones a nivel global por una razón: su poder y flexibilidad son inigualables. Al ser de código abierto, no estás atado a un proveedor ni a planes restrictivos. Esto nos permite adaptarlo, modificarlo y escalarlo para que se ajuste perfectamente a tus objetivos pedagógicos y de negocio, convirtiéndolo en una verdadera universidad corporativa o en un campus virtual de primer nivel."
  },
  {
    id: "lms-aws",
    name: "Alojamiento en AWS: Rendimiento, Escalabilidad y Control Total",
    description: "Tu plataforma vivirá en la infraestructura de Amazon Web Services, garantizando velocidad y la capacidad de crecer sin límites.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-2.087-5.032.75.75 0 00-.832.075l-.039.04G9.95 4.125a3.75 3.75 0 00-5.922 2.04.75.75 0 00.033.515l.096.16a4.5 4.5 0 004.37 2.417H10.5" /></svg>`,
    media: { type: 'localVideo', src: '/videos/features/lms-aws.mp4' },
    descriptiveText: "Olvídate de los hostings compartidos que se caen con 50 usuarios simultáneos. Montamos tu Moodle sobre AWS, lo que te da una potencia y escalabilidad elástica. Puedes empezar con 10 usuarios y crecer a 10,000 sin que el rendimiento se vea afectado. Además, este control total nos permite optimizar la base de datos y el código para un rendimiento y seguridad que las soluciones 'enlatadas' simplemente no pueden ofrecer."
  },
  {
    id: "lms-accessibility",
    name: "Accesibilidad Real: Aprendizaje para Todos",
    description: "Gracias al control total sobre el código, garantizamos que tu plataforma cumpla con los más altos estándares de accesibilidad.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m-7.5-2.928A9.09 9.09 0 005.25 18.72m-8.384-2.88a3 3 0 014.682-2.72m-12.122.992A9.09 9.09 0 013.75 18.72m12.54-1.665a9.094 9.094 0 01-3.742-.479m-8.383-2.928a9.09 9.09 0 013.742-.479M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    media: { type: 'localImage', src: '/images/features/lms-accessibility.jpg' },
    descriptiveText: "La accesibilidad no es una opción, es una obligación. Las plataformas LMS estándar a menudo presentan barreras para usuarios con discapacidades. Al tener acceso completo al código y la base de datos en AWS, podemos modificar temas, plugins y la estructura misma del sitio para cumplir con normativas como WCAG, asegurando que el conocimiento sea accesible para cada miembro de tu equipo o alumnado, sin excepciones."
  },
  {
    id: "lms-implementation",
    name: "Implementación y Consultoría Experta: Desde Cero o Rescate",
    description: "Tanto si empiezas un nuevo proyecto como si necesitas revitalizar una plataforma existente, nuestro equipo es tu mejor aliado.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.664 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.474-4.474c-.048-.58-.026-1.193-.14-1.743m-2.114 2.114a2.25 2.25 0 10-3.182-3.182M12 5.25v.007" /></svg>`,
    media: { type: 'localImage', src: '/images/features/lms-setup.jpg' },
    descriptiveText: "Lanzamos tu nueva plataforma Moodle desde la planificación inicial hasta la puesta en marcha, asegurando una configuración óptima de temas, plugins y categorías. ¿Ya tienes un Moodle lento, desactualizado o con problemas? Lo revitalizamos. Realizamos auditorías de rendimiento, actualizaciones de versión, migraciones de datos y reparamos instalaciones defectuosas para devolverle la vida y la funcionalidad a tu inversión."
  },
  {
    id: "lms-content",
    name: "Más Allá de la Plataforma: Creación de Contenido y Video",
    description: "Te ayudamos a transformar tu conocimiento en cursos interactivos y material audiovisual de alta calidad que realmente enganchen.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9A2.25 2.25 0 004.5 18.75z" /></svg>`,
    media: { type: 'localVideo', src: '/videos/features/lms-content.mp4' },
    descriptiveText: "Una plataforma potente necesita contenido potente. Nuestro equipo pedagógico y de producción trabaja contigo para diseñar experiencias de aprendizaje efectivas. Convertimos manuales estáticos en módulos interactivos con quizzes, foros y actividades. Además, contamos con servicio de grabación y edición de video profesional para tus capacitaciones, procedimientos o clases magistrales, asegurando un acabado de alta calidad."
  },
  {
    id: "lms-corporate",
    name: "El Cerebro de tu Empresa: Onboarding y Capacitación Corporativa",
    description: "Utiliza tu LMS para estandarizar la inducción de nuevos empleados y mantener a tu equipo actualizado con formación continua.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6h1.5m-1.5 3h1.5m-1.5 3h1.5M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
    media: { type: 'localImage', src: '/images/features/lms-corporate.jpg' },
    descriptiveText: "Un LMS es mucho más que un repositorio de cursos. Es una herramienta estratégica de negocio. Automatiza y estandariza el proceso de onboarding, asegurando que cada nuevo empleado reciba la misma formación de alta calidad. Lanza programas de capacitación continua para desarrollar nuevas habilidades en tu equipo, gestiona certificaciones y realiza seguimiento del cumplimiento normativo. Centraliza el conocimiento y potencia el crecimiento de tu talento."
  }
];

const featureSections = [
    {
        title: "Nuestros Servicios LMS con Moodle",
        features: lmsFeatures
    }
];
---

<ProductPageLayout
  pageTitle={pageTitle}
  serviceName={serviceName}
  leadParagraph={leadParagraph}
  featureSections={featureSections}
/>