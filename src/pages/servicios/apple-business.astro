<style>
:root{
  --bg:#fff;--surface:#fff;--border:#e4e4e7;--border-strong:#18181b;
  --accent:#18181b;--accent-fg:#fff;--accent-sub:#f4f4f5;
  --indigo:#85a03a;--indigo-sub:#f4f7e9;--indigo-strong:#6d8530;
  --green:#16a34a;--green-sub:#f0fdf4;
  --amber:#d97706;--amber-sub:#fffbeb;
  --text:#18181b;--text2:#52525b;--text3:#a1a1aa;
  --r:8px;--font:'Inter',-apple-system,sans-serif;
}
body.dark{
  --bg:#030303;--surface:#0f0f0f;--border:#1f1f1f;--border-strong:#fafafa;
  --accent:#fafafa;--accent-fg:#0a0a0a;--accent-sub:#141414;
  --indigo:#a6c04d;--indigo-sub:#1a1a2e;--indigo-strong:#b5ca6c;
  --green:#4ade80;--green-sub:#042a12;
  --amber:#f59e0b;--amber-sub:#1c1410;
  --text:#fafafa;--text2:#a1a1aa;--text3:#52525b;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:background .2s}
body.dark nav{background:rgba(3,3,3,.85)}
.logo{font-size:14px;font-weight:800;letter-spacing:-.4px;color:var(--text)}
.logo em{color:var(--indigo);font-style:normal}
.nav-links{display:flex;gap:2px}
.nl{font-size:13px;color:var(--text2);padding:5px 11px;border-radius:var(--r);transition:all .15s;font-weight:500}
.nl:hover{color:var(--text);background:var(--accent-sub)}
.nl.on{color:var(--text)}
.nav-r{display:flex;gap:6px;align-items:center}
.icon-btn{width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text2);transition:all .15s}
.icon-btn:hover{border-color:var(--text3);color:var(--text)}
.lang-wrap{display:flex;border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.lb{padding:3px 10px;font-size:12px;font-weight:600;border:none;background:none;color:var(--text2);cursor:pointer;font-family:var(--font)}
.lb.on{background:var(--accent);color:var(--accent-fg)}
.btn-nav{display:flex;align-items:center;gap:5px;padding:6px 14px;border-radius:var(--r);font-size:13px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text);font-family:var(--font);transition:all .15s}
.btn-nav:hover{background:var(--accent-sub)}

/* HERO */
.hero{padding:120px 28px 60px;position:relative;overflow:hidden;border-bottom:1px solid var(--border)}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:60px 60px;opacity:.35;pointer-events:none}
.hero::after{content:'';position:absolute;top:-30%;left:50%;transform:translateX(-50%);width:900px;height:900px;background:radial-gradient(ellipse,rgba(133,160,58,.08) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:880px;margin:0 auto;width:100%;position:relative;z-index:1;text-align:center}
.hero-eyebrow{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border:1px solid var(--border);border-radius:20px;font-size:11px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--indigo);background:var(--indigo-sub);margin-bottom:24px}
.hero-eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--indigo);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero-h1{font-size:clamp(36px,5vw,58px);font-weight:900;letter-spacing:-1.5px;line-height:1.05;margin-bottom:16px;color:var(--text)}
.hero-sub{font-size:clamp(17px,2vw,20px);font-weight:500;color:var(--text2);line-height:1.5;max-width:640px;margin:0 auto 12px}
.hero-sub .accent{color:var(--indigo);font-weight:700}
.hero-cta{margin-top:32px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:var(--r);font-size:14px;font-weight:600;border:1px solid var(--accent);background:var(--accent);color:var(--accent-fg);transition:all .15s}
.btn-primary:hover{opacity:.88}
.btn-secondary{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:var(--r);font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--text2);transition:all .15s}
.btn-secondary:hover{border-color:var(--text3);color:var(--text)}

/* ARTICLE / CONTENT */
.section{max-width:860px;margin:0 auto;padding:64px 28px}
.section-narrow{max-width:720px;margin:0 auto;padding:48px 28px}
h2{font-size:clamp(26px,3vw,34px);font-weight:800;letter-spacing:-.7px;line-height:1.2;margin:0 0 20px;color:var(--text)}
h3{font-size:clamp(18px,2vw,20px);font-weight:700;letter-spacing:-.3px;line-height:1.3;margin:32px 0 10px;color:var(--text)}
p{font-size:17px;line-height:1.75;color:var(--text);margin-bottom:16px;font-weight:400}
p strong{color:var(--text);font-weight:700}
.section ul{margin:0 0 20px 0;padding-left:0;list-style:none}
.section ul li{position:relative;padding-left:22px;margin-bottom:10px;font-size:16px;line-height:1.65;color:var(--text)}
.section ul li::before{content:'';position:absolute;left:0;top:9px;width:7px;height:7px;border-radius:50%;background:var(--indigo)}

/* PROBLEM BLOCK */
.problem{background:var(--accent-sub);border:1px solid var(--border);border-radius:14px;padding:36px 32px;margin:32px 0}
.problem .problem-q{font-size:22px;font-weight:700;letter-spacing:-.3px;margin-bottom:16px;color:var(--text);line-height:1.3}
.problem p{font-size:16px;line-height:1.7;margin-bottom:12px;color:var(--text2)}
.problem ul li{color:var(--text2)}

/* FEATURES grid */
.features{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:24px 0}
.feat{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px;transition:border-color .15s}
.feat:hover{border-color:var(--text3)}
.feat-head{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.feat-num{width:24px;height:24px;border-radius:6px;background:var(--indigo-sub);color:var(--indigo);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.feat h4{font-size:15px;font-weight:700;color:var(--text);letter-spacing:-.2px;margin:0}
.feat p{font-size:14px;color:var(--text2);line-height:1.55;margin:0}

/* PHASES */
.phases{margin:28px 0}
.phase{display:grid;grid-template-columns:90px 1fr;gap:24px;padding:20px 0;border-bottom:1px solid var(--border)}
.phase:last-child{border-bottom:none}
.phase-num{font-size:32px;font-weight:900;color:var(--indigo);letter-spacing:-1px;line-height:1}
.phase-body h4{font-size:17px;font-weight:700;margin-bottom:6px;color:var(--text)}
.phase-body p{font-size:14.5px;line-height:1.65;color:var(--text2);margin-bottom:6px}
.phase-time{font-size:12px;font-weight:600;color:var(--text3);letter-spacing:.4px;text-transform:uppercase}

/* PACKAGES */
.pkgs{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin:24px 0}
.pkg{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px}
.pkg.featured{border-color:var(--indigo);background:var(--indigo-sub)}
.pkg-label{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:8px}
.pkg.featured .pkg-label{color:var(--indigo)}
.pkg-name{font-size:20px;font-weight:800;letter-spacing:-.3px;margin-bottom:8px;color:var(--text)}
.pkg-desc{font-size:14px;color:var(--text2);line-height:1.6;margin-bottom:16px}
.pkg-list{list-style:none;padding:0;margin:0}
.pkg-list li{font-size:13.5px;color:var(--text);line-height:1.55;padding:6px 0 6px 24px;position:relative}
.pkg-list li::before{content:'✓';position:absolute;left:0;top:5px;color:var(--indigo);font-weight:700}

/* FAQ */
.faq-wrap{margin:28px 0;display:flex;flex-direction:column;gap:8px}
.faq-item{border:1px solid var(--border);border-radius:10px;padding:0;overflow:hidden;background:var(--surface)}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;font-size:15px;font-weight:600;color:var(--text);gap:12px}
.faq-q::after{content:'+';font-size:18px;color:var(--text3);font-weight:400;transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--indigo)}
.faq-a{display:none;padding:0 20px 18px;font-size:14.5px;color:var(--text2);line-height:1.7}
.faq-item.open .faq-a{display:block}

/* CTA FINAL */
.cta-final{background:var(--accent);color:var(--accent-fg);border-radius:14px;padding:48px 36px;text-align:center;margin:48px auto;max-width:720px}
.cta-final h3{color:var(--accent-fg);font-size:28px;margin:0 0 10px 0;font-weight:800;letter-spacing:-.5px}
.cta-final p{color:var(--accent-fg);opacity:.85;margin-bottom:24px;font-size:16px}
.cta-final .btn-cta{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:var(--accent-fg);color:var(--accent);border-radius:var(--r);font-weight:700;font-size:15px;transition:transform .15s;text-decoration:none}
.cta-final .btn-cta:hover{transform:translateY(-1px)}

/* DISCLAIMER */
.disclaimer{max-width:720px;margin:48px auto 0;padding:24px 28px;background:var(--accent-sub);border:1px solid var(--border);border-radius:10px;font-size:12.5px;line-height:1.6;color:var(--text3)}
.disclaimer strong{color:var(--text2)}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:24px 28px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.footer-left{display:flex;align-items:center;gap:20px}
.footer-link{font-size:12px;color:var(--text3);transition:color .15s}
.footer-link:hover{color:var(--text2)}
.fc{display:flex;align-items:center;gap:5px;font-size:13px;color:var(--text2)}
.fc a{color:var(--text2);transition:color .15s}
.fc a:hover{color:var(--text)}

/* Hamburger */
.hamburger{display:none;width:30px;height:30px;border-radius:var(--r);border:1px solid var(--border);background:none;cursor:pointer;align-items:center;justify-content:center;color:var(--text2);transition:all .15s;flex-shrink:0}
.mob-menu{display:none;position:fixed;top:52px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:12px 16px 16px;flex-direction:column;gap:2px;z-index:199;box-shadow:0 8px 24px rgba(0,0,0,.08)}
body.dark .mob-menu{box-shadow:0 8px 24px rgba(0,0,0,.35)}
.mob-menu.open{display:flex}
.mob-link{font-size:15px;font-weight:500;color:var(--text2);padding:10px 12px;border-radius:var(--r);display:block}
.mob-link:hover,.mob-link.on{color:var(--text);background:var(--accent-sub)}
.mob-divider{height:1px;background:var(--border);margin:6px 0}

@media(max-width:900px){
  .features, .pkgs{grid-template-columns:1fr}
  .phase{grid-template-columns:70px 1fr;gap:16px}
  .phase-num{font-size:26px}
  .section{padding:48px 24px}
  .hero{padding:96px 24px 48px}
  .problem{padding:28px 24px}
  .cta-final{padding:36px 24px}
}
@media(max-width:768px){
  .nav-links,.btn-nav{display:none!important}
  .hamburger{display:flex}
  .lang-wrap{display:none}
}
</style>
