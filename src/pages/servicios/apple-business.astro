<!-- METHODOLOGY PHASES -->
<section class="section">
  <h2 data-es="Metodología en 5 fases" data-en="5-phase methodology">Metodología en 5 fases</h2>
  <p data-es="Implementación estructurada con entregables claros en cada fase. Timeline típico para una empresa con 20-100 dispositivos:" data-en="Structured implementation with clear deliverables in each phase. Typical timeline for a company with 20-100 devices:">Implementación estructurada con entregables claros en cada fase. Timeline típico para una empresa con 20-100 dispositivos:</p>

  <div class="phases">
    <div class="phase">
      <div class="phase-num">0</div>
      <div class="phase-body">
        <h4 data-es="Auditoría" data-en="Audit">Auditoría</h4>
        <p data-es="Inventario completo de dispositivos, cuentas Apple existentes, estado DNS, MDM actual (si existe), políticas vigentes. Informe con brechas y plan de trabajo." data-en="Complete inventory of devices, existing Apple accounts, DNS status, current MDM (if any), existing policies. Report with gaps and work plan.">Inventario completo de dispositivos, cuentas Apple existentes, estado DNS, MDM actual (si existe), políticas vigentes. Informe con brechas y plan de trabajo.</p>
        <p class="phase-time" data-es="Tiempo típico: 1 semana" data-en="Typical time: 1 week">Tiempo típico: 1 semana</p>
      </div>
    </div>
    <div class="phase">
      <div class="phase-num">1</div>
      <div class="phase-body">
        <h4 data-es="Setup del portal y dominio" data-en="Portal and domain setup">Setup del portal y dominio</h4>
        <p data-es="Verificación del dominio corporativo, creación del portal ABM, configuración de roles administrativos, políticas de seguridad base." data-en="Corporate domain verification, ABM portal creation, administrative roles configuration, base security policies.">Verificación del dominio corporativo, creación del portal ABM, configuración de roles administrativos, políticas de seguridad base.</p>
        <p class="phase-time" data-es="Tiempo típico: 1 semana" data-en="Typical time: 1 week">Tiempo típico: 1 semana</p>
      </div>
    </div>
    <div class="phase">
      <div class="phase-num">2</div>
      <div class="phase-body">
        <h4 data-es="Migración de cuentas" data-en="Account migration">Migración de cuentas</h4>
        <p data-es="Creación de Managed Apple IDs para todos los empleados, comunicación del proceso al equipo, migración asistida de datos personales a cuentas personales donde aplique." data-en="Creation of Managed Apple IDs for all employees, process communication to the team, assisted migration of personal data to personal accounts where applicable.">Creación de Managed Apple IDs para todos los empleados, comunicación del proceso al equipo, migración asistida de datos personales a cuentas personales donde aplique.</p>
        <p class="phase-time" data-es="Tiempo típico: 2 a 3 semanas" data-en="Typical time: 2 to 3 weeks">Tiempo típico: 2 a 3 semanas</p>
      </div>
    </div>
    <div class="phase">
      <div class="phase-num">3</div>
      <div class="phase-body">
        <h4 data-es="MDM, VPP y DEP" data-en="MDM, VPP and DEP">MDM, VPP y DEP</h4>
        <p data-es="Integración con el MDM elegido, inscripción de dispositivos, setup de VPP y DEP, políticas de compliance (passcode, encryption, restricciones). Tests de alta, baja y reset remoto." data-en="Integration with chosen MDM, device enrollment, VPP and DEP setup, compliance policies (passcode, encryption, restrictions). Tests for onboarding, offboarding and remote reset.">Integración con el MDM elegido, inscripción de dispositivos, setup de VPP y DEP, políticas de compliance (passcode, encryption, restricciones). Tests de alta, baja y reset remoto.</p>
        <p class="phase-time" data-es="Tiempo típico: 1 a 2 semanas" data-en="Typical time: 1 to 2 weeks">Tiempo típico: 1 a 2 semanas</p>
      </div>
    </div>
    <div class="phase">
      <div class="phase-num">4</div>
      <div class="phase-body">
        <h4 data-es="Capacitación + soporte" data-en="Training + support">Capacitación + soporte</h4>
        <p data-es="Manual personalizado entregado, 2 a 3 sesiones de capacitación (administradores y empleados), resolución de dudas iniciales. Transición a soporte continuo." data-en="Custom manual delivered, 2 to 3 training sessions (administrators and employees), initial questions resolution. Transition to ongoing support.">Manual personalizado entregado, 2 a 3 sesiones de capacitación (administradores y empleados), resolución de dudas iniciales. Transición a soporte continuo.</p>
        <p class="phase-time" data-es="Continuo desde el mes 2" data-en="Ongoing from month 2">Continuo desde el mes 2</p>
      </div>
    </div>
  </div>
</section>

